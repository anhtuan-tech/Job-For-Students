<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - J4S | Job For Students</title>
    <meta name="description" content="J4S - Nền tảng kết nối micro-job cho sinh viên. Tìm việc làm thêm, freelance dễ dàng." />
    <link rel="icon" type="image/png" href="~/images/j4s_favicon.png" />
    <meta property="og:image" content="~/images/j4s_logo.png" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Lucide Icons (CDN) -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Dashboard CSS -->
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    @RenderBody()

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
