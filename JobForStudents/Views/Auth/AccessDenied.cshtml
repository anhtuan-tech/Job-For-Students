@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f8fafc; font-family: 'Inter', sans-serif;">
    <div style="text-align: center; max-width: 480px; padding: 40px 24px;">
        <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #fee2e2, #fecaca); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-size: 2.5rem;">
            🔒
        </div>
        <h1 style="font-size: 2rem; font-weight: 800; color: #0f172a; margin-bottom: 12px;">Không có quyền truy cập</h1>
        <p style="font-size: 1rem; color: #64748b; line-height: 1.6; margin-bottom: 32px;">
            Bạn không có quyền truy cập vào trang này.<br />
            Vui lòng đăng nhập đúng tài khoản hoặc liên hệ quản trị viên.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            <a asp-controller="Home" asp-action="Index"
               style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg, #0ea5e9, #2563eb); color: white; font-weight: 700; border-radius: 12px; text-decoration: none; font-size: 0.9rem; transition: all 0.2s;">
                🏠 Về trang chủ
            </a>
            <a asp-controller="Auth" asp-action="Login"
               style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: #f1f5f9; color: #0f172a; font-weight: 700; border-radius: 12px; text-decoration: none; font-size: 0.9rem; border: 1.5px solid #e2e8f0; transition: all 0.2s;">
                🔑 Đăng nhập lại
            </a>
        </div>
    </div>
</div>
