@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="auth-page-container">
    <!-- Left Showcase Side -->
    <div class="auth-showcase-panel">
        <div class="auth-bg-shapes">
            <div class="auth-shape auth-shape-1"></div>
            <div class="auth-shape auth-shape-2"></div>
            <div class="auth-shape auth-shape-3"></div>
        </div>

        <!-- Branding Logo -->
        <a href="/" class="auth-brand" style="color: #ffffff;">
            <div class="auth-logo-icon" style="background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.25); box-shadow: none;">
                <i data-lucide="graduation-cap" style="width: 24px; height: 24px;"></i>
            </div>
            <span class="auth-logo-text" style="color: #ffffff;">J4S</span>
        </a>

        <!-- Showcase Message -->
        <div class="auth-showcase-content">
            <h1>Khôi Phục Mật Khẩu Nhanh Chóng</h1>
            <p>Hệ thống tự động bảo mật cao. Chỉ cần cung cấp email đã đăng ký để nhận mã OTP xác thực và thiết lập lại mật khẩu mới.</p>
            
            <!-- Dynamic Glassmorphic Stats -->
            <div class="auth-stats-grid">
                <div class="auth-stat-card">
                    <span class="auth-stat-number">10K+</span>
                    <span class="auth-stat-label">Sinh viên hoạt động</span>
                </div>
                <div class="auth-stat-card">
                    <span class="auth-stat-number">98%</span>
                    <span class="auth-stat-label">Tỷ lệ hoàn thành</span>
                </div>
                <div class="auth-stat-card">
                    <span class="auth-stat-number">500+</span>
                    <span class="auth-stat-label">Doanh nghiệp tin cậy</span>
                </div>
                <div class="auth-stat-card">
                    <span class="auth-stat-number">Escrow</span>
                    <span class="auth-stat-label">Thanh toán bảo mật</span>
                </div>
            </div>
        </div>

        <!-- Footer Note -->
        <div style="font-size: 0.85rem; opacity: 0.75; font-weight: 500; position: relative; z-index: 2;">
            &copy; 2026 J4S Platform. Kết nối tương lai.
        </div>
    </div>

    <!-- Right Form Side -->
    <div class="auth-form-panel">
        <div class="auth-form-wrapper">
            
            <!-- Branding for Mobile -->
            <div class="d-flex d-md-none justify-content-center mb-4">
                <a href="/" class="auth-brand">
                    <div class="auth-logo-icon">
                        <i data-lucide="graduation-cap" style="width: 24px; height: 24px;"></i>
                    </div>
                    <span class="auth-logo-text">J4S</span>
                </a>
            </div>

            <!-- STEP 1: Enter Email -->
            <div id="stepEmail">
                <div class="mb-4 text-center text-md-start">
                    <h2 style="font-size: 1.85rem; font-weight: 800; color: #0f172a; margin-bottom: 8px;">Quên mật khẩu?</h2>
                    <p style="color: #64748b; font-size: 0.95rem; margin: 0;">Nhập email đăng ký của bạn để nhận mã xác minh OTP.</p>
                </div>

                <form id="formSendOtp" onsubmit="handleSendOtp(event)">
                    <!-- Email Input -->
                    <div class="input-group-modern mb-4">
                        <label for="emailInput">Email đăng nhập</label>
                        <div class="input-field-container">
                            <span class="input-field-icon">
                                <i data-lucide="mail" style="width: 18px; height: 18px;"></i>
                            </span>
                            <input id="emailInput" type="email" class="input-field-modern" placeholder="name@example.com" required />
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-auth-submit" id="btnSendOtp">
                        Gửi mã OTP
                    </button>

                    <div class="text-center mt-4" style="font-size: 0.9rem; color: #64748b;">
                        Quay lại <a href="/Auth/Login" style="color: #2563eb; font-weight: 700; text-decoration: none;">Đăng nhập</a>
                    </div>
                </form>
            </div>

            <!-- STEP 2: Verify OTP -->
            <div id="stepVerifyOtp" style="display: none;">
                <div class="mb-4 text-center text-md-start">
                    <h2 style="font-size: 1.85rem; font-weight: 800; color: #0f172a; margin-bottom: 8px;">Xác thực mã OTP</h2>
                    <p style="color: #64748b; font-size: 0.95rem; margin: 0;">Chúng tôi đã gửi OTP đến email của bạn. Hãy nhập mã OTP gồm 6 chữ số dưới đây.</p>
                </div>

                <form id="formVerifyOtp" onsubmit="handleVerifyOtp(event)">
                    <!-- OTP Input -->
                    <div class="input-group-modern mb-4">
                        <label for="otpInput">Mã OTP (6 chữ số)</label>
                        <div class="input-field-container">
                            <span class="input-field-icon">
                                <i data-lucide="shield-check" style="width: 18px; height: 18px;"></i>
                            </span>
                            <input id="otpInput" type="text" class="input-field-modern" placeholder="XXXXXX" required maxlength="6" pattern="\d{6}" autocomplete="off" />
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-auth-submit" id="btnVerifyOtp">
                        Xác thực mã OTP
                    </button>

                    <div class="text-center mt-4" style="font-size: 0.9rem; color: #64748b;">
                        <a href="#" onclick="showStepEmail(event)" style="color: #64748b; font-weight: 500; text-decoration: none;"> Quay lại bước trước</a>
                    </div>
                </form>
            </div>

            <!-- STEP 3: Enter New Password -->
            <div id="stepNewPassword" style="display: none;">
                <div class="mb-4 text-center text-md-start">
                    <h2 style="font-size: 1.85rem; font-weight: 800; color: #0f172a; margin-bottom: 8px;">Đặt lại mật khẩu</h2>
                    <p style="color: #64748b; font-size: 0.95rem; margin: 0;">Mã OTP hợp lệ! Hãy điền mật khẩu mới của bạn bên dưới.</p>
                </div>

                <form id="formResetPassword" onsubmit="handleResetPassword(event)">
                    <!-- New Password Input -->
                    <div class="input-group-modern">
                        <label for="newPasswordInput">Mật khẩu mới</label>
                        <div class="input-field-container">
                            <span class="input-field-icon">
                                <i data-lucide="lock" style="width: 18px; height: 18px;"></i>
                            </span>
                            <input id="newPasswordInput" type="password" class="input-field-modern" placeholder="••••••" required minlength="6" autocomplete="new-password" />
                        </div>
                    </div>

                    <!-- Confirm Password Input -->
                    <div class="input-group-modern mb-4">
                        <label for="confirmPasswordInput">Xác nhận mật khẩu</label>
                        <div class="input-field-container">
                            <span class="input-field-icon">
                                <i data-lucide="lock" style="width: 18px; height: 18px;"></i>
                            </span>
                            <input id="confirmPasswordInput" type="password" class="input-field-modern" placeholder="••••••" required minlength="6" autocomplete="new-password" />
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-auth-submit" id="btnResetPassword">
                        Xác nhận đặt lại mật khẩu
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        let userEmail = "";
        let verifiedOtp = "";

        function showStepEmail(e) {
            if (e) e.preventDefault();
            document.getElementById('stepEmail').style.display = 'block';
            document.getElementById('stepVerifyOtp').style.display = 'none';
            document.getElementById('stepNewPassword').style.display = 'none';
        }

        function showStepVerifyOtp() {
            document.getElementById('stepEmail').style.display = 'none';
            document.getElementById('stepVerifyOtp').style.display = 'block';
            document.getElementById('stepNewPassword').style.display = 'none';
        }

        function showStepNewPassword() {
            document.getElementById('stepEmail').style.display = 'none';
            document.getElementById('stepVerifyOtp').style.display = 'none';
            document.getElementById('stepNewPassword').style.display = 'block';
        }

        async function handleSendOtp(e) {
            e.preventDefault();
            const email = document.getElementById('emailInput').value.trim();
            if (!email) return;

            const btn = document.getElementById('btnSendOtp');
            btn.disabled = true;
            btn.textContent = "Đang gửi OTP...";

            try {
                const response = await fetch('/Auth/SendOtp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email: email })
                });

                const data = await response.json();
                if (data.success) {
                    userEmail = email;
                    showToast(data.message, 'success');
                    showStepVerifyOtp();
                } else {
                    showToast(data.message || 'Gửi OTP thất bại.', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Có lỗi kết nối xảy ra.', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = "Gửi mã OTP";
            }
        }

        async function handleVerifyOtp(e) {
            e.preventDefault();
            const otp = document.getElementById('otpInput').value.trim();
            if (!otp) return;

            const btn = document.getElementById('btnVerifyOtp');
            btn.disabled = true;
            btn.textContent = "Đang xác thực...";

            try {
                const response = await fetch('/Auth/VerifyOtp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email: userEmail, otp: otp })
                });

                const data = await response.json();
                if (data.success) {
                    verifiedOtp = otp;
                    showToast(data.message, 'success');
                    showStepNewPassword();
                } else {
                    showToast(data.message || 'Xác thực OTP thất bại.', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Có lỗi kết nối xảy ra.', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = "Xác thực mã OTP";
            }
        }

        async function handleResetPassword(e) {
            e.preventDefault();
            const newPassword = document.getElementById('newPasswordInput').value;
            const confirmPassword = document.getElementById('confirmPasswordInput').value;

            if (newPassword !== confirmPassword) {
                showToast('Mật khẩu xác nhận không khớp.', 'error');
                return;
            }

            if (newPassword.length < 6) {
                showToast('Mật khẩu phải có ít nhất 6 ký tự.', 'error');
                return;
            }

            const btn = document.getElementById('btnResetPassword');
            btn.disabled = true;
            btn.textContent = "Đang xử lý...";

            try {
                const response = await fetch('/Auth/VerifyOtpAndResetPassword', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        email: userEmail,
                        otp: verifiedOtp,
                        newPassword: newPassword,
                        confirmPassword: confirmPassword
                    })
                });

                const data = await response.json();
                if (data.success) {
                    showToast('Đặt lại mật khẩu thành công! Đang chuyển hướng...', 'success');
                    setTimeout(() => {
                        window.location.href = '/Auth/Login';
                    }, 2000);
                } else {
                    showToast(data.message || 'Đặt lại mật khẩu thất bại.', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Có lỗi kết nối xảy ra.', 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = "Xác nhận đặt lại mật khẩu";
            }
        }
    </script>
}
