                        <div style="height: 100px; background: linear-gradient(135deg, #eff6ff, #dbeafe); display: flex; align-items: center; justify-content: center; color: #2563eb;"><i data-lucide="pen-tool" style="width: 32px; height: 32px;"></i></div>
                        <div style="padding: 16px;">
                            <h3 style="font-size: 0.95rem; font-weight: 700; color: #1e293b; margin: 0 0 8px 0; line-height: 1.4;">Viết Proposal chinh phục khách hàng</h3>
                            <p style="font-size: 0.8rem; color: #64748b; margin: 0; line-height: 1.5;">Học cách giới thiệu bản thân khiến nhà tuyển dụng không thể từ chối.</p>
                        </div>
                    </div>
                    <!-- Card 2 -->
                    <div data-tip-id="tip-time" onclick="openTipModal('tip-time')" style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.01); transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div style="height: 100px; background: linear-gradient(135deg, #ecfdf5, #d1fae5); display: flex; align-items: center; justify-content: center; color: #10b981;"><i data-lucide="clock" style="width: 32px; height: 32px;"></i></div>
