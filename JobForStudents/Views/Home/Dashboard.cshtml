                    <div class="sidebar-submenu" id="walletSubmenu" style="display:none; flex-direction:column; gap:4px; padding-left:16px; border-left:1.5px solid #e2e8f0; margin-left:20px; margin-top:4px;">
                        <a href="#" class="sidebar-item" data-nav="wallet-current" id="navWalletCurrent" style="font-size:0.85rem; padding:8px 12px;">
                            <span class="item-icon"><i data-lucide="package" style="width:14px;height:14px;"></i></span>
