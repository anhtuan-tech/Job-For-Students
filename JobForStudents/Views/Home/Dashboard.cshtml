                <div class="sidebar-label">Việc làm</div>
                <a href="#" class="sidebar-item active" data-nav="home" id="navHome">
                    <span class="item-icon"><i data-lucide="home" style="width:18px;height:18px;"></i></span>
                    Trang chủ
                </a>
                <a href="#" class="sidebar-item" data-nav="find" id="navFindJob">
                    <span class="item-icon"><i data-lucide="search" style="width:18px;height:18px;"></i></span>
                    Tìm việc
                </a>
                <a href="#" class="sidebar-item" data-nav="saved" id="navSaved">
                    <span class="item-icon"><i data-lucide="bookmark" style="width:18px;height:18px;"></i></span>
                    Việc đã lưu
                </a>
                <a href="#" class="sidebar-item" data-nav="applied" id="navApplied">
                    <span class="item-icon"><i data-lucide="send" style="width:18px;height:18px;"></i></span>
                    Đã ứng tuyển
                </a>
                <a href="#" class="sidebar-item" data-nav="projects" id="navProjects">
                    <span class="item-icon"><i data-lucide="folder-open" style="width:18px;height:18px;"></i></span>
                    Dự án đang làm
                </a>
            </div>

            <!-- Nhóm: QUẢN LÝ -->
            <div class="sidebar-group">
                <div class="sidebar-label">Quản lý</div>
                @if (User.IsInRole("Business"))
                {
                    <a href="#" class="sidebar-item" data-nav="businessJobs" id="navBusinessJobs">
                        <span class="item-icon"><i data-lucide="briefcase-business" style="width:18px;height:18px;"></i></span>
                        Quản lý tin đăng
                    </a>
                    <a href="#" class="sidebar-item" data-nav="servicePackages" id="navServicePackages">
                        <span class="item-icon"><i data-lucide="package-check" style="width:18px;height:18px;"></i></span>
