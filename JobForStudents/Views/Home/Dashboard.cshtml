                    <div class="candidates-header">
                        <h2 class="candidates-title">Ứng viên mới nhất</h2>
                        <a href="#" class="candidates-link" id="btnSeeAllCandidates">Xem tất cả <i data-lucide="chevron-down" style="width:14px;height:14px;"></i></a>
                    </div>
                    <div class="candidates-list">
                        @if (Model.BusinessRecentApplicants.Count == 0)
                        {
                            <div class="text-center py-4 text-muted w-100">
                                <p class="mb-0">Chưa có ứng viên mới ứng tuyển.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var candidate in Model.BusinessRecentApplicants)
                            {
                                var gradient = avatarGradients[candidate.Id % avatarGradients.Length];
                                <div class="candidate-item">
                                    <div class="candidate-left">
                                        <div class="candidate-avatar" style="background: @(string.IsNullOrEmpty(candidate.AvatarUrl) ? gradient : "none"); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; overflow: hidden;">
                                            @if (!string.IsNullOrEmpty(candidate.AvatarUrl))
                                            {
                                                <img src="@candidate.AvatarUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                @candidate.Initials
                                            }
                                        </div>
                                        <div>
                                            <div class="candidate-name">
                                                @candidate.FullName
                                                @if (candidate.MatchLevel == "match-high")
                                                {
                                                    <span class="candidate-badge match-high">Phù hợp cao</span>
                                                }
                                                else
                                                {
                                                    <span class="candidate-badge match-medium">Phù hợp trung bình</span>
                                                }
                                            </div>
                                            <div class="candidate-role">@candidate.Role</div>
                                        </div>
                                    </div>
                                    <div class="candidate-right">
                                        <span class="candidate-time">@candidate.TimeAgo</span>
                                        <button class="btn-view-profile-sm" onclick="window.location.href='/StudentProfile/Details?id=@candidate.Id'">Xem hồ sơ</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </section>
            </main>

            <!-- ============================================
                  4A. CỘT PHẢI - THÔNG TIN DOANH NGHIỆP
                  ============================================ -->
            <aside class="right-sidebar" id="rightSidebar">
                @if (Model.BusinessRecentJobs.Any())
                {
                    <!-- Recent Postings Widget -->
                    <div class="recent-posts-widget">
                        <div class="recent-posts-header">
                            <h3 class="recent-posts-title">Tin đăng gần đây</h3>
                            <a href="#" class="candidates-link" id="btnSeeAllJobs" style="font-size:0.8rem;">Xem tất cả <i data-lucide="chevron-down" style="width:12px;height:12px;"></i></a>
                        </div>
                        <div class="recent-posts-list">
                            @foreach (var rJob in Model.BusinessRecentJobs)
                            {
                                // Determine Lucide icon for category
                                var iconName = "briefcase";
                                var categoryLower = rJob.Category.ToLower();
                                if (categoryLower.Contains("code") || categoryLower.Contains("web")) iconName = "code-2";
                                else if (categoryLower.Contains("design") || categoryLower.Contains("thiết kế") || categoryLower.Contains("palette")) iconName = "palette";
                                else if (categoryLower.Contains("video") || categoryLower.Contains("edit")) iconName = "video";
                                else if (categoryLower.Contains("content") || categoryLower.Contains("viết")) iconName = "pen-tool";
                                else if (categoryLower.Contains("slide") || categoryLower.Contains("trình bày")) iconName = "presentation";
                                else if (categoryLower.Contains("dịch") || categoryLower.Contains("translate") || categoryLower.Contains("ngôn ngữ")) iconName = "languages";

                                var statusText = "Đang hiển thị";
                                var statusClass = "active";
                                if (rJob.Status == "Warning")
                                {
                                    statusText = "Sắp hết hạn";
                                    statusClass = "warning";
                                }
                                else if (rJob.Status == "Paused")
                                {
                                    statusText = "Tạm dừng";
                                    statusClass = "paused";
                                }

                                <div class="recent-post-item">
                                    <div class="recent-post-left">
                                        <div class="recent-post-icon"><i data-lucide="@iconName" style="width:16px;height:16px;"></i></div>
                                        <div class="recent-post-info">
                                            <div class="recent-post-jobtitle">@rJob.Title</div>
                                            <div class="recent-post-candidates" style="display:flex; gap: 8px; color: #64748b; font-size: 0.75rem;">
                                                <span><i data-lucide="eye" style="width:12px;height:12px;margin-bottom:-2px"></i> @rJob.ViewCount</span>
                                                <span><i data-lucide="users" style="width:12px;height:12px;margin-bottom:-2px"></i> @rJob.TotalApplicantsCount</span>
                                                <span style="color: #0d9488;">(Mới: @rJob.NewApplicantsCount)</span>
                                            </div>
                                        </div>
                                    </div>
                                    <span class="recent-post-status @statusClass">@statusText</span>
                                </div>
                            }
                        </div>
                        <button class="btn-sidebar-outline" id="btnManageJobsSidebar">Quản lý tin đăng</button>
                    </div>
                }

                <!-- Current Service Package Widget -->
                <div class="service-pkg-widget">
                    <h3 class="service-pkg-title">Gói dịch vụ hiện tại</h3>
                    <div class="service-pkg-card" id="sidebarServicePkgCard">
                        @if (Model.ActivePackageName == "Gói Premium")
                        {
                            var premiumProgress = Math.Min(100, Model.ActivePackageUsedCount * 100 / 20);
                            <div class="service-pkg-header">
                                <span class="service-pkg-name"><i data-lucide="star" style="width:18px;height:18px;color:#f59e0b;fill:#f59e0b;"></i> Gói Premium</span>
                                <span class="service-pkg-status active" style="background:#d1fae5; color:#065f46; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Đang hoạt động</span>
                            </div>
                            <div class="service-pkg-expiry">Hiệu lực đến: @Model.ActivePackageExpiry</div>
                            <div class="service-pkg-bullets">
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 20 tin tuyển dụng</span></div>
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị tin ưu tiên</span></div>
                                <div class="service-pkg-bullet" style="padding-left: 22px;"><span>Truy cập hồ sơ ứng viên không giới hạn</span></div>
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hỗ trợ tuyển dụng ưu tiên</span></div>
                            </div>
                            <div class="service-pkg-usage">
                                <span>Đã sử dụng</span>
                                <span>@Model.ActivePackageUsedCount/20 tin</span>
                            </div>
                            <div class="service-pkg-progress-bar">
                                <div class="service-pkg-progress-fill" style="width: @(premiumProgress)%;"></div>
                            </div>
                        }
                        else if (Model.ActivePackageName == "Gói VIP")
                        {
                            var vipProgress = Math.Min(100, Model.ActivePackageUsedCount * 100 / 5);
                            <div class="service-pkg-header">
                                <span class="service-pkg-name"><i data-lucide="star" style="width:18px;height:18px;color:#f59e0b;fill:#f59e0b;"></i> Gói VIP</span>
                                <span class="service-pkg-status active" style="background:#fef3c7; color:#92400e; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Đang hoạt động</span>
                            </div>
                            <div class="service-pkg-expiry">Hiệu lực đến: @Model.ActivePackageExpiry</div>
                            <div class="service-pkg-bullets">
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 5 tin tuyển dụng</span></div>
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị nhãn VIP nổi bật</span></div>
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Duyệt tin nhanh trong 1 giờ</span></div>
                            </div>
                            <div class="service-pkg-usage">
                                <span>Đã sử dụng</span>
                                <span>@Model.ActivePackageUsedCount/5 tin</span>
                            </div>
                            <div class="service-pkg-progress-bar">
                                <div class="service-pkg-progress-fill" style="width: @(vipProgress)%;"></div>
                            </div>
                        }
                        else
                        {
                            var freeProgress = Model.ActivePackageUsedCount >= 1 ? 100 : 0;
                            <div class="service-pkg-header">
                                <span class="service-pkg-name"><i data-lucide="briefcase" style="width:18px;height:18px;color:#64748b;"></i> Gói Thường</span>
                                <span class="service-pkg-status text-muted" style="background:#f1f5f9; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Mặc định</span>
                            </div>
                            <div class="service-pkg-expiry">Hiệu lực: Vĩnh viễn</div>
                            <div class="service-pkg-bullets">
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 1 tin tuyển dụng</span></div>
                                <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị chuẩn trên trang chủ</span></div>
                            </div>
                            <div class="service-pkg-usage">
                                <span>Đã sử dụng</span>
                                <span>@Model.ActivePackageUsedCount/1 tin</span>
                            </div>
                            <div class="service-pkg-progress-bar">
                                <div class="service-pkg-progress-fill" style="width: @(freeProgress)%;"></div>
                            </div>
                        }
                    </div>
                </div>
            </aside>
        }
        else
        {
            <!-- ============================================
                 3B. CỘT GIỮA - NỘI DUNG MẶC ĐỊNH / FREELANCER
                 ============================================ -->
            <main class="main-content" id="mainContent">

                <!-- === Banner chào mừng === -->
                <section class="welcome-banner" id="welcomeBanner" style="margin-bottom: 24px;">
                    <div class="banner-text">
                        <h1>Chào mừng bạn đến với J4S!</h1>
                        <p>Tìm kiếm công việc freelance linh hoạt phù hợp với lịch học của bạn.</p>
                        <div class="banner-actions">
                            <button class="btn-primary-main" id="btnFindJobNow" style="background:#2563eb; border:none; padding:12px 24px; border-radius:30px; font-weight:600; color:white; display:inline-flex; align-items:center; gap:8px;">
                                <i data-lucide="search" style="width:16px;height:16px;"></i>
                                Tìm việc ngay
                            </button>
                        </div>
                    </div>
                    <div class="banner-illustration">
                        <img src="~/images/student_working.png" alt="Sinh viên làm việc với laptop" />
                    </div>
                </section>

                <!-- === Tổng quan hoạt động === -->
                <section style="margin-bottom: 28px;">
                    <div class="section-header" style="margin-bottom: 16px;">
                        <h2 class="section-title" style="font-size: 1.25rem; font-weight: 800; color: #0f172a;">Hoạt động của bạn</h2>
                    </div>
                    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
                        <!-- Đã ứng tuyển -->
                        <div class="stat-card" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 14px;">
                            <div style="background: #eff6ff; color: #2563eb; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="send" style="width: 22px; height: 22px;"></i></div>
                            <div>
                                <div style="font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1.2;">@Model.StudentAppliedJobs.Count</div>
                                <div style="font-size: 0.8rem; font-weight: 600; color: #64748b;">Đã ứng tuyển</div>
                            </div>
                        </div>
                        <!-- Hợp đồng hoạt động -->
                        <div class="stat-card" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 14px;">
                            <div style="background: #ecfdf5; color: #10b981; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="file-check" style="width: 22px; height: 22px;"></i></div>
                            <div>
                                <div style="font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1.2;">@Model.StudentActiveContracts.Count</div>
                                <div style="font-size: 0.8rem; font-weight: 600; color: #64748b;">Đang thực hiện</div>
                            </div>
                        </div>
                        <!-- Công việc đã lưu -->
                        <div class="stat-card" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 14px;">
                            <div style="background: #fffbeb; color: #f59e0b; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="bookmark" style="width: 22px; height: 22px;"></i></div>
                            <div>
                                <div style="font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1.2;">@Model.Jobs.Count(j => j.IsSaved)</div>
                                <div style="font-size: 0.8rem; font-weight: 600; color: #64748b;">Việc làm đã lưu</div>
                            </div>
                        </div>
                        <!-- Đã hoàn thành -->
                        <div class="stat-card" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 14px;">
                            <div style="background: #faf5ff; color: #a855f7; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="award" style="width: 22px; height: 22px;"></i></div>
                            <div>
                                <div style="font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1.2;">@Model.CompletedJobsCount</div>
                                <div style="font-size: 0.8rem; font-weight: 600; color: #64748b;">Đã hoàn thành</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- === Danh mục phổ biến === -->
                <section id="popularCategories" style="margin-bottom: 28px;">
                    <div class="section-header" style="margin-bottom: 16px;">
                        <h2 class="section-title" style="font-size: 1.25rem; font-weight: 800; color: #0f172a;">Lĩnh vực phổ biến</h2>
                    </div>
                    <div class="categories-grid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px;">
                        <!-- IT & Lập trình -->
                        <div class="category-card animate-in" data-category="IT & Lập trình" style="cursor: pointer; padding: 18px; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; text-align: center; transition: all 0.2s;">
                            <div class="category-icon" style="background: #eff6ff; color: #2563eb; width: 48px; height: 48px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                                <i data-lucide="code-2" style="width:24px;height:24px;"></i>
                            </div>
                            <div class="category-name" style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">IT & Lập trình</div>
                        </div>
                        <!-- Thiết kế & Đồ họa -->
                        <div class="category-card animate-in" data-category="Thiết kế & Đồ họa" style="cursor: pointer; padding: 18px; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; text-align: center; transition: all 0.2s;">
                            <div class="category-icon" style="background: #ecfdf5; color: #10b981; width: 48px; height: 48px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                                <i data-lucide="palette" style="width:24px;height:24px;"></i>
                            </div>
                            <div class="category-name" style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">Thiết kế & Đồ họa</div>
                        </div>
                        <!-- Viết lách & Dịch thuật -->
                        <div class="category-card animate-in" data-category="Viết lách & Dịch thuật" style="cursor: pointer; padding: 18px; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; text-align: center; transition: all 0.2s;">
                            <div class="category-icon" style="background: #fffbeb; color: #f59e0b; width: 48px; height: 48px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                                <i data-lucide="languages" style="width:24px;height:24px;"></i>
                            </div>
                            <div class="category-name" style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">Viết lách & Dịch thuật</div>
                        </div>
                        <!-- Sales & Marketing -->
                        <div class="category-card animate-in" data-category="Sales & Marketing" style="cursor: pointer; padding: 18px; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; text-align: center; transition: all 0.2s;">
                            <div class="category-icon" style="background: #fdf2f8; color: #db2777; width: 48px; height: 48px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                                <i data-lucide="megaphone" style="width:24px;height:24px;"></i>
                            </div>
                            <div class="category-name" style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">Sales & Marketing</div>
                        </div>
                        <!-- Video & Photography -->
                        <div class="category-card animate-in" data-category="Video & Photography" style="cursor: pointer; padding: 18px; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; text-align: center; transition: all 0.2s;">
                            <div class="category-icon" style="background: #faf5ff; color: #9333ea; width: 48px; height: 48px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
                                <i data-lucide="video" style="width:24px;height:24px;"></i>
                            </div>
                            <div class="category-name" style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">Video & Photography</div>
                        </div>
                    </div>
                </section>

                <!-- === Dự án nổi bật (Featured Jobs Grid) === -->
                <section id="featuredJobs" style="margin-bottom: 28px;">
                    <div class="section-header" style="margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center;">
                        <h2 class="section-title" style="font-size: 1.25rem; font-weight: 800; color: #0f172a;">🔥 Dự án nổi bật trong tuần</h2>
                        <a href="#" onclick="document.getElementById('navFindJob').click(); return false;" style="font-size: 0.85rem; font-weight: 600; color: #2563eb; text-decoration: none;">Xem tất cả <i data-lucide="chevron-right" style="width:14px;height:14px;vertical-align:middle;"></i></a>
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                        @{
                            var iconMap = new Dictionary<string, (string cls, string icon)>
                            {
                                ["IT & Lập trình"] = ("#eff6ff", "code-2"),
                                ["Thiết kế & Đồ họa"] = ("#ecfdf5", "palette"),
                                ["Viết lách & Dịch thuật"] = ("#fffbeb", "languages"),
                                ["Sales & Marketing"] = ("#fdf2f8", "megaphone"),
                                ["Video & Photography"] = ("#faf5ff", "video")
                            };
                            
                            var colorMap = new Dictionary<string, string>
                            {
                                ["IT & Lập trình"] = "#2563eb",
                                ["Thiết kế & Đồ họa"] = "#10b981",
                                ["Viết lách & Dịch thuật"] = "#f59e0b",
                                ["Sales & Marketing"] = "#db2777",
                                ["Video & Photography"] = "#9333ea"
                            };
                        }
                        @foreach (var job in Model.Jobs.Take(3))
                        {
                            var info = iconMap.GetValueOrDefault(job.Category, ("#f1f5f9", "briefcase"));
                            var iconColor = colorMap.GetValueOrDefault(job.Category, "#64748b");
                            var budgetFormatted = string.Format("{0:N0} đ", job.Budget);
                            
                            <div style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; display: flex; flex-direction: column; transition: all 0.2s; box-shadow: 0 4px 15px rgba(0,0,0,0.01); cursor: pointer;" onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='#cbd5e1'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.05)';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.01)';">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px;">
                                    <div style="background: @info.Item1; color: @iconColor; width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                        <i data-lucide="@info.Item2" style="width: 22px; height: 22px;"></i>
                                    </div>
                                    <div style="background: #f8fafc; border: 1px solid #e2e8f0; color: #475569; font-size: 0.7rem; font-weight: 700; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px;">@job.Category</div>
                                </div>
                                <h3 style="font-size: 1.05rem; font-weight: 800; color: #1e293b; margin-bottom: 8px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 42px;">@job.Title</h3>
                                <div style="font-size: 1.25rem; font-weight: 800; color: #10b981; margin-bottom: 16px;">@budgetFormatted</div>
                                <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f1f5f9; padding-top: 14px;">
                                    <div style="font-size: 0.8rem; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                                        <i data-lucide="clock" style="width: 14px; height: 14px;"></i> @job.Deadline
                                    </div>
                                    <div style="font-size: 0.8rem; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                                        <i data-lucide="users" style="width: 14px; height: 14px;"></i> @job.ApplicantsCount
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

            </main>

        <!-- ============================================
                 4B. CỘT PHẢI - TRANG TRÍ (BÍ KÍP)
                 ============================================ -->
        <aside class="right-sidebar" id="rightSidebar">
            <!-- === Cẩm nang & Kỹ năng Freelancer === -->
            <div class="widget-card" style="border: none; box-shadow: none; background: transparent;">
                <div class="widget-header" style="margin-bottom: 16px;">
