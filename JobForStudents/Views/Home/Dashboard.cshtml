    /* Sidebar submenus */
    .sidebar-submenu {
        display: none;
        flex-direction: column;
        gap: 4px;
        margin-top: 4px;
        padding-left: 16px;
        border-left: 1.5px solid #e2e8f0;
        margin-left: 20px;
    }

        .sidebar-submenu.show {
