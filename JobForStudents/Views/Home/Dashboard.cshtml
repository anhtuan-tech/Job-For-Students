                        </a>
                        <a href="#" class="sidebar-item" data-nav="wallet-history" id="navWalletHistory" style="font-size:0.85rem; padding:8px 12px;">
                            <span class="item-icon"><i data-lucide="history" style="width:14px;height:14px;"></i></span>
