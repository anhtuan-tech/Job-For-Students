            window.purchaseServicePackage = async function(packageName, price, currentBalance) {
            if (currentBalance < price) {
            showToast('Số dư tài khoản không đủ. Vui lòng nạp thêm tiền!', 'warning');
            setTimeout(() => {
            document.getElementById('navWalletDeposit')?.click();
            }, 1000);
            return;
            }

            if (!confirm(`Bạn có chắc chắn muốn mua gói dịch vụ ${packageName} với giá ${new Intl.NumberFormat('vi-VN').format(price)} đ không?`)) {
            return;
            }

            try {
            const response = await fetch('/Home/PurchasePackage', {
            method: 'POST',
            headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
            },
            body: JSON.stringify({ PackageName: packageName })
            });

            const data = await response.json();
            if (data.success) {
            showToast(`Chúc mừng! Bạn đã mua thành công gói ${packageName}!`, 'success');
            window.renderBusinessWalletCurrent();
            } else {
            showToast(data.message || 'Có lỗi xảy ra khi mua gói.', 'error');
            }
            } catch (e) {
            console.error('Error purchasing package:', e);
            showToast('Lỗi mạng. Vui lòng kiểm tra kết nối.', 'error');
            }
            }

