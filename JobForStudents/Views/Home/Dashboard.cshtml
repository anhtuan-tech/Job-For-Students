            verifyBtn.disabled = false;
            verifyBtn.innerHTML = `<i data-lucide="check-circle" class="me-2" style="width:20px;height:20px;vertical-align:text-bottom;"></i>Tôi đã chuyển khoản thành công`;
            if (window.lucide) lucide.createIcons();
            }
            }
            } catch (e) {
            console.error('Error verifying deposit:', e);
            showToast('Không thể kết nối đối soát. Vui lòng thử lại.', 'error');
            if (verifyBtn) {
            verifyBtn.disabled = false;
            verifyBtn.innerHTML = `<i data-lucide="check-circle" class="me-2" style="width:20px;height:20px;vertical-align:text-bottom;"></i>Tôi đã chuyển khoản thành công`;
            if (window.lucide) lucide.createIcons();
            }
            }
            }

            window.renderBusinessWalletHistory = async function() {
            if (window.depositCountdownInterval) {
            clearInterval(window.depositCountdownInterval);
            }
            const mainContent = document.getElementById('mainContent');
            if (!mainContent) return;

            mainContent.innerHTML = `
            <div class="d-flex justify-content-center align-items-center py-5">
            <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
            </div>
            </div>
            `;

            const walletData = await getWalletData();
            if (!walletData || !walletData.success) {
            mainContent.innerHTML = `
            <div class="alert alert-danger" role="alert">
            Không thể tải thông tin ví. Vui lòng thử lại sau.
            </div>
            `;
            return;
            }

            if (walletData.transactions.length === 0) {
            mainContent.innerHTML = `
            <div class="page-header mb-4">
            <h1 class="page-title"><i data-lucide="history" style="width:24px;height:24px;"></i> Lịch sử giao dịch</h1>
            <p class="page-subtitle">Xem toàn bộ lịch sử nạp và thanh toán</p>
            </div>
            <div class="card border-0 shadow-sm p-5 text-center" style="border-radius:16px;">
            <p class="text-muted mb-0">Bạn chưa thực hiện bất kỳ giao dịch nào.</p>
            </div>
            `;
            if (window.lucide) lucide.createIcons();
            return;
            }

            let txRowsHTML = '';
            walletData.transactions.forEach(t => {
            let typeBadge = '';
            let amountClass = '';
            let amountSign = '';

            if (t.type === 'Deposit') {
            typeBadge = '<span class="badge bg-success-subtle text-success px-2.5 py-1.5 small rounded-pill">Nạp tiền</span>';
            amountClass = 'text-success';
            amountSign = '+';
            } else if (t.type === 'Holding') {
            typeBadge = '<span class="badge bg-indigo-subtle text-indigo px-2.5 py-1.5 small rounded-pill">Thanh toán gói</span>';
            amountClass = 'text-danger';
            amountSign = '-';
            } else {
            typeBadge = `<span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 small rounded-pill">${t.type}</span>`;
            amountClass = 'text-muted';
            amountSign = '';
            }

            let statusBadge = '';
            if (t.status === 'Success') {
            statusBadge = '<span class="badge bg-success px-2.5 py-1.5 small rounded-pill"><i data-lucide="check" class="me-1" style="width:12px;height:12px;"></i>Thành công</span>';
            } else if (t.status === 'Pending') {
            statusBadge = '<span class="badge bg-warning text-dark px-2.5 py-1.5 small rounded-pill"><i data-lucide="loader" class="me-1 animate-spin" style="width:12px;height:12px;"></i>Đang chờ</span>';
            } else {
            statusBadge = `<span class="badge bg-danger px-2.5 py-1.5 small rounded-pill">${t.status}</span>`;
            }

            txRowsHTML += `
            <tr>
            <td class="fw-semibold text-slate-700">#${t.transactionCode || t.id}</td>
            <td>${typeBadge}</td>
            <td class="fw-bold ${amountClass}">${amountSign} ${new Intl.NumberFormat('vi-VN').format(t.amount)} đ</td>
            <td class="small text-slate-600" style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${t.description || ''}">${t.description || '-'}</td>
            <td><span class="text-slate-500 small">${t.createdAt}</span></td>
            <td>${statusBadge}</td>
            </tr>
            `;
            });

            mainContent.innerHTML = `
            <div class="page-header mb-4">
            <h1 class="page-title"><i data-lucide="history" style="width:24px;height:24px;"></i> Lịch sử giao dịch</h1>
            <p class="page-subtitle">Xem chi tiết lịch sử nạp và thanh toán gói dịch vụ</p>
            </div>

            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius:16px;">
            <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="background:#fff;">
            <thead class="table-light text-slate-700" style="background:#f8fafc; font-weight: 600;">
            <tr>
            <th scope="col" class="py-3 px-4 border-0">Mã GD</th>
            <th scope="col" class="py-3 border-0">Loại</th>
            <th scope="col" class="py-3 border-0">Số tiền</th>
            <th scope="col" class="py-3 border-0">Mô tả</th>
            <th scope="col" class="py-3 border-0">Thời gian</th>
            <th scope="col" class="py-3 px-4 border-0">Trạng thái</th>
            </tr>
            </thead>
            <tbody>
            ${txRowsHTML}
            </tbody>
            </table>
            </div>
            </div>
            `;

            if (window.lucide) lucide.createIcons();
            }
        </script>
    }

    @if (User.IsInRole("Admin"))
    {
        <script>
            const adminPendingJobsData = @Html.Raw(Json.Serialize(Model.AdminPendingJobs ?? new List<AdminPendingJobViewModel>()));

            window.adminDataCache = {
                users: [],
                pendingJobs: [],
                allJobs: [],
                txs: [],
                support: [],
                feedback: []
            };

            window.adminPageState = {
                users: { currentPage: 1, pageSize: 10 },
                pendingJobs: { currentPage: 1, pageSize: 5 },
                allJobs: { currentPage: 1, pageSize: 10 },
                txs: { currentPage: 1, pageSize: 10 },
                support: { currentPage: 1, pageSize: 10 },
                feedback: { currentPage: 1, pageSize: 10 }
            };

            window.triggerReloadAdminList = function(listKey) {
                if (listKey === 'users') renderAdminUsers(true);
                else if (listKey === 'pendingJobs' || listKey === 'allJobs') renderAdminJobs(true);
                else if (listKey === 'txs') renderAdminTxs(true);
                else if (listKey === 'support') renderAdminSupport(true);
                else if (listKey === 'feedback') renderAdminFeedback(true);
            };

            window.renderAdminTable = function(listKey, data, headers, rowRenderer, containerId = 'adminSectionBody') {
                if (!window.adminPageState[listKey]) {
                    window.adminPageState[listKey] = { currentPage: 1, pageSize: 10 };
                }
                const state = window.adminPageState[listKey];
                const container = document.getElementById(containerId);
                if (!container) return;

                const totalItems = data.length;
                const totalPages = Math.ceil(totalItems / state.pageSize) || 1;
                if (state.currentPage > totalPages) state.currentPage = totalPages;
                if (state.currentPage < 1) state.currentPage = 1;

                const startIndex = (state.currentPage - 1) * state.pageSize;
                const endIndex = Math.min(startIndex + state.pageSize, totalItems);
                const pageData = data.slice(startIndex, endIndex);

                const finalHeaders = ['STT', ...headers];

                let html = `
                <div class="table-responsive w-100">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                ${finalHeaders.map(h => `<th>${h}</th>`).join('')}
                            </tr>
                        </thead>
                        <tbody>
                `;

                if (totalItems === 0) {
                    html += `<tr><td colspan="${finalHeaders.length}" class="text-center text-muted py-4">Chưa có dữ liệu.</td></tr>`;
                } else {
                    pageData.forEach((item, index) => {
                        const globalIndex = startIndex + index + 1;
                        const rowCells = rowRenderer(item, globalIndex);
                        html += `
                        <tr>
                            <td class="fw-bold text-center" style="width: 60px; color: #64748b;">${globalIndex}</td>
                            ${rowCells}
                        </tr>`;
                    });
                }

                html += `
                        </tbody>
                    </table>
                </div>
                `;

                if (totalItems > 0) {
                    const pageSizeOptions = [5, 10, 15, 20, 30, 50];
                    const selectOptions = pageSizeOptions.map(size => `<option value="${size}" ${size === state.pageSize ? 'selected' : ''}>${size}</option>`).join('');

                    html += `
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mt-4 p-3 bg-light rounded-3 border" style="font-size: 0.9rem;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-secondary">Hiển thị</span>
                            <select class="form-select form-select-sm" style="width: auto; font-weight: 600;" onchange="window.adminPageState['${listKey}'].pageSize = parseInt(this.value); window.adminPageState['${listKey}'].currentPage = 1; triggerReloadAdminList('${listKey}');">
                                ${selectOptions}
                            </select>
                            <span class="text-secondary">kết quả / trang</span>
                        </div>
                        
                        <div class="text-secondary font-medium">
                            Hiển thị <strong>${totalItems === 0 ? 0 : startIndex + 1}-${endIndex}</strong> trong tổng số <strong>${totalItems}</strong> kết quả
                        </div>
                        
                        <div class="d-flex align-items-center gap-1">
                            <button class="btn btn-sm btn-outline-secondary ${state.currentPage === 1 ? 'disabled' : ''}" onclick="window.adminPageState['${listKey}'].currentPage = 1; triggerReloadAdminList('${listKey}');">« Đầu</button>
                            <button class="btn btn-sm btn-outline-secondary ${state.currentPage === 1 ? 'disabled' : ''}" onclick="window.adminPageState['${listKey}'].currentPage--; triggerReloadAdminList('${listKey}');">‹ Trước</button>
                            
                            <span class="px-3 text-secondary">Trang <strong>${state.currentPage}</strong> / <strong>${totalPages}</strong></span>
                            
                            <button class="btn btn-sm btn-outline-secondary ${state.currentPage === totalPages ? 'disabled' : ''}" onclick="window.adminPageState['${listKey}'].currentPage++; triggerReloadAdminList('${listKey}');">Sau ›</button>
                            <button class="btn btn-sm btn-outline-secondary ${state.currentPage === totalPages ? 'disabled' : ''}" onclick="window.adminPageState['${listKey}'].currentPage = ${totalPages}; triggerReloadAdminList('${listKey}');">Cuối »</button>
                        </div>
                    </div>
                    `;
                }

                container.innerHTML = html;
            };

            document.addEventListener('DOMContentLoaded', () => {
                // Initialize Admin Panel
                initAdminPanel();
            });

            async function initAdminPanel() {
                // Load stats first
                await updateAdminStats();

                // Set up navigation
                const navHome = document.getElementById('adminNavHome');
                const navUsers = document.getElementById('adminNavUsers');
                const navJobs = document.getElementById('adminNavJobs');
                const navTxs = document.getElementById('adminNavTxs');
                const navSupport = document.getElementById('adminNavSupport');
                const navFeedback = document.getElementById('adminNavFeedback');
                const navItems = [navHome, navUsers, navJobs, navTxs, navSupport, navFeedback];

                function clearActive() {
                    navItems.forEach(item => item?.classList.remove('active'));
                }

                navHome?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navHome.classList.add('active');
                    renderAdminHome();
                });

                navUsers?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navUsers.classList.add('active');
                    renderAdminUsers();
                });

                navJobs?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navJobs.classList.add('active');
                    renderAdminJobs();
                });

                navTxs?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navTxs.classList.add('active');
                    renderAdminTxs();
                });

                navSupport?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navSupport.classList.add('active');
                    renderAdminSupport();
                });

                navFeedback?.addEventListener('click', (e) => {
                    e.preventDefault();
                    clearActive();
                    navFeedback.classList.add('active');
                    renderAdminFeedback();
                });

                // Render initial home view
                renderAdminHome();
            }

            async function updateAdminStats() {
                try {
                    const res = await fetch('/Home/GetAdminStats');
                    const stats = await res.json();

                    document.getElementById('statUsers').textContent = stats.totalUsers;
                    document.getElementById('statJobs').textContent = stats.totalJobs;
                    document.getElementById('statContracts').textContent = stats.totalContracts;
                    document.getElementById('statRevenue').textContent = new Intl.NumberFormat('vi-VN').format(stats.systemRevenue) + ' đ';
                    document.getElementById('statVolume').textContent = new Intl.NumberFormat('vi-VN').format(stats.systemVolume) + ' đ';
                } catch (err) {
                    console.error('Error fetching admin stats:', err);
                }
            }

            function showSpinner(container) {
                container.innerHTML = `
                <div style="display:flex; justify-content:center; align-items:center; min-height:200px; width:100%;">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>`;
            }

            async function renderAdminHome() {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Tổng quan hệ thống";
                showSpinner(body);

                await updateAdminStats();

                const currentYear = new Date().getFullYear();

                body.innerHTML = `
                <div class="admin-home-grid">
                    <div class="admin-home-panel">
                        <div class="admin-hero">
                            <div>
                                <h3>Trung tâm điều hành hệ thống J4S</h3>
                                <p>Giám sát an toàn nền tảng, chất lượng dữ liệu và trạng thái giao dịch theo thời gian thực.</p>
                            </div>
                            <div class="admin-kpi-inline">
                                <i data-lucide="shield-check" style="width:16px;height:16px;"></i>
                                Hệ thống ổn định
                            </div>
                        </div>

                        <h3 style="font-size:0.95rem; font-weight:800; margin-bottom:12px; color:#334155; display:flex; align-items:center; gap:8px;">
                            <i data-lucide="shield-alert" style="color:#ef4444; width:17px; height:17px;"></i>
                            Nguyên tắc kiểm duyệt quan trọng
                        </h3>
                        <ul style="font-size:0.84rem; color:#64748b; padding-left:18px; line-height:1.9; margin:0;">
                            <li>Khóa tài khoản khi có bằng chứng gian lận hoặc spam đã được xác minh.</li>
                            <li>Gỡ tin tuyển dụng vi phạm chính sách nội dung hoặc thông tin sai lệch.</li>
                            <li>Bảo toàn lịch sử giao dịch và nhật ký xử lý để phục vụ đối soát.</li>
                        </ul>
                    </div>

                    <div class="admin-home-panel">
                        <h3 style="font-size:0.95rem; font-weight:800; margin-bottom:12px; color:#334155; display:flex; align-items:center; gap:8px;">
                            <i data-lucide="activity" style="color:#10b981; width:17px; height:17px;"></i>
                            Trạng thái hệ thống
                        </h3>
                        <div class="admin-system-list">
                            <div class="admin-system-item">
                                <span>Kết nối Database</span>
                                <span class="badge bg-success" style="padding:4px 8px; border-radius:12px;">Bình thường</span>
                            </div>
                            <div class="admin-system-item">
                                <span>Cổng thanh toán</span>
                                <span class="badge bg-success" style="padding:4px 8px; border-radius:12px;">Đang hoạt động</span>
                            </div>
                            <div class="admin-system-item">
                                <span>Gửi email tự động</span>
                                <span class="badge bg-success" style="padding:4px 8px; border-radius:12px;">Đang kết nối</span>
                            </div>
                        </div>
                        <div class="admin-quick-actions">
                            <button class="admin-quick-btn" onclick="document.getElementById('adminNavUsers')?.click()">Quản lý người dùng</button>
                            <button class="admin-quick-btn" onclick="document.getElementById('adminNavJobs')?.click()">Duyệt tin tuyển dụng</button>
                            <button class="admin-quick-btn" onclick="document.getElementById('adminNavTxs')?.click()">Kiểm tra giao dịch</button>
                        </div>
                    </div>
                </div>

                <div class="admin-chart-panel">
                    <h3>
                        <i data-lucide="trending-up" style="color:#2563eb; width:19px; height:19px;"></i>
                        Doanh thu gói & dòng tiền nạp vào hệ thống năm ${currentYear}
                    </h3>
                    <div style="position: relative; height: 350px; width: 100%;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
                `;

                if (window.lucide) lucide.createIcons();

                let txs = window.adminDataCache.txs;
                if (!txs || txs.length === 0) {
                    try {
                        const res = await fetch('/Home/GetAdminTransactions');
                        txs = await res.json();
                        window.adminDataCache.txs = txs;
                    } catch (err) {
                        console.error("Error loading transactions for charts:", err);
                        txs = [];
                    }
                }
                initAdminCharts(txs);
            }

            function initAdminCharts(txs) {
                const monthlyData = Array(12).fill(0).map(() => ({ deposit: 0, packages: 0 }));
                const currentYear = new Date().getFullYear();

                txs.forEach(t => {
                    if (t.status !== 'Success') return;

                    const datePart = t.createdAt.split(' ')[0]; // "dd/MM/yyyy"
                    const parts = datePart.split('/');
                    if (parts.length === 3) {
                        const month = parseInt(parts[1], 10);
                        const year = parseInt(parts[2], 10);

                        if (year === currentYear && month >= 1 && month <= 12) {
                            if (t.type === 'Deposit') {
                                monthlyData[month - 1].deposit += t.amount;
                            } else if (t.type === 'Withdraw') {
                                const desc = (t.description || '').toLowerCase();
                                if (desc.includes('gói') || desc.includes('plan') || desc.includes('vip') || desc.includes('premium')) {
                                    monthlyData[month - 1].packages += t.amount;
                                }
                            }
                        }
                    }
                });

                const monthLabels = ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'];
                const depositDataset = monthlyData.map(d => d.deposit);
                const packageDataset = monthlyData.map(d => d.packages);

                function createChartInstances() {
                    if (!window.Chart) {
                        setTimeout(createChartInstances, 100);
                        return;
                    }

                    const ctxRev = document.getElementById('revenueChart');

                    if (ctxRev) {
                        new Chart(ctxRev, {
                            type: 'bar',
                            data: {
                                labels: monthLabels,
                                datasets: [
                                    {
                                        label: 'Tiền nạp vào ví (đ)',
                                        data: depositDataset,
                                        backgroundColor: 'rgba(37, 99, 235, 0.65)',
                                        borderColor: '#2563eb',
                                        borderWidth: 1,
                                        type: 'bar',
                                        yAxisID: 'y'
                                    },
                                    {
                                        label: 'Doanh thu gói dịch vụ (đ)',
                                        data: packageDataset,
                                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                                        borderColor: '#10b981',
                                        borderWidth: 2.5,
                                        fill: true,
                                        type: 'line',
                                        tension: 0.35,
                                        yAxisID: 'y1'
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { position: 'top' }
                                },
                                scales: {
                                    y: {
                                        type: 'linear',
                                        display: true,
                                        position: 'left',
                                        beginAtZero: true,
                                        ticks: {
                                            callback: function(value) {
                                                return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
                                            }
                                        },
                                        title: {
                                            display: true,
                                            text: 'Tiền nạp ví',
                                            font: { weight: 'bold' }
                                        }
                                    },
                                    y1: {
                                        type: 'linear',
                                        display: true,
                                        position: 'right',
                                        beginAtZero: true,
                                        grid: {
                                            drawOnChartArea: false
                                        },
                                        ticks: {
                                            callback: function(value) {
                                                return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
                                            }
                                        },
                                        title: {
                                            display: true,
                                            text: 'Doanh thu gói',
                                            font: { weight: 'bold' }
                                        }
                                    }
                                }
                            }
                        });
                    }
                }

                createChartInstances();
            }

            async function renderAdminUsers(isPagedReload = false) {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Quản lý người dùng";

                if (!isPagedReload || !window.adminDataCache.users || window.adminDataCache.users.length === 0) {
                    showSpinner(body);
                    try {
                        const res = await fetch('/Home/GetAdminUsers');
                        window.adminDataCache.users = await res.json();
                    } catch (err) {
                        body.innerHTML = '<p class="text-danger text-center py-4">Lỗi khi tải dữ liệu người dùng.</p>';
                        console.error(err);
                        return;
                    }
                }

                const users = window.adminDataCache.users;
                const headers = ['Tên hiển thị', 'Email', 'Số điện thoại', 'Vai trò', 'Ngày đăng ký', 'Trạng thái', 'Thao tác'];

                const rowRenderer = (u, globalIndex) => {
                    const statusBadge = u.status === 'Active'
                        ? '<span class="admin-badge active">Hoạt động</span>'
                        : '<span class="admin-badge banned">Đang khóa</span>';

                    const roleBadge = u.role === 'Student'
                        ? '<span class="admin-badge student">Sinh viên</span>'
                        : u.role === 'Business'
                        ? '<span class="admin-badge business">Doanh nghiệp</span>'
                        : '<span class="admin-badge" style="background:#e2e8f0; color:#334155;">Admin</span>';

                    const actionBtn = u.role === 'Admin'
                        ? '<span class="text-muted small">Mặc định</span>'
                        : u.status === 'Active'
                        ? `<button class="btn-admin-action ban" onclick="toggleUserStatus(${u.id})">Khóa tài khoản</button>`
                        : `<button class="btn-admin-action unban" onclick="toggleUserStatus(${u.id})">Mở khóa</button>`;

                    return `
                        <td class="fw-semibold">${escapeHtml(u.displayName || 'Chưa cập nhật')}</td>
                        <td>${escapeHtml(u.email)}</td>
                        <td>${escapeHtml(u.phone || 'N/A')}</td>
                        <td>${roleBadge}</td>
                        <td>${u.createdAt}</td>
                        <td id="user-status-${u.id}">${statusBadge}</td>
                        <td id="user-action-${u.id}">${actionBtn}</td>
                    `;
                };

                window.renderAdminTable('users', users, headers, rowRenderer, 'adminSectionBody');
            }

            async function toggleUserStatus(userId) {
                if (!confirm("Bạn có chắc chắn muốn thay đổi trạng thái hoạt động của tài khoản này?")) return;

                try {
                    const resToggle = await fetch(`/Home/ToggleUserStatus?userId=${userId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    });
                    const data = await resToggle.json();

                    if (data.success) {
                        showToast("Cập nhật trạng thái thành công!", "success");
                        window.adminDataCache.users = []; // invalidate cache
                        renderAdminUsers(false);
                        updateAdminStats();
                    } else {
                        showToast(data.message || "Lỗi khi cập nhật trạng thái.", "error");
                    }
                } catch (err) {
                    console.error(err);
                    showToast("Không thể kết nối đến máy chủ.", "error");
                }
            }

            async function renderAdminJobs(isPagedReload = false) {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Quản lý tin tuyển dụng";

                window.adminDataCache.pendingJobs = adminPendingJobsData || [];

                if (!isPagedReload || !window.adminDataCache.allJobs || window.adminDataCache.allJobs.length === 0) {
                    showSpinner(body);
                    try {
                        const res = await fetch('/Home/GetAdminJobs');
                        window.adminDataCache.allJobs = await res.json();
                    } catch (err) {
                        body.innerHTML = '<p class="text-danger text-center py-4">Lỗi khi tải danh sách tin tuyển dụng.</p>';
                        console.error(err);
                        return;
                    }
                }

                body.innerHTML = `
                    <h4 class="mb-3 fw-bold" style="color: #0f172a;">Tin tuyển dụng chờ duyệt</h4>
                    <div id="pendingJobsContainer" class="mb-5"></div>
                    
                    <h4 class="mb-3 fw-bold" style="color: #0f172a;">Tất cả tin tuyển dụng</h4>
                    <div id="allJobsContainer"></div>
                `;

                // 1. Render pending jobs
                const pendingHeaders = ['Tiêu đề công việc', 'Doanh nghiệp đăng', 'Ngày tạo', 'Thao tác'];
                const pendingRowRenderer = (j, globalIndex) => {
                    return `
                        <td class="fw-semibold">${escapeHtml(j.title)}</td>
                        <td>${escapeHtml(j.companyName)}</td>
                        <td>${j.createdAt}</td>
                        <td>
                            <button class="btn-admin-action" style="background:#10b981; color:white; border-color:#10b981;" onclick="approveJob(${j.id})">Duyệt</button>
                            <button class="btn-admin-action delete" onclick="rejectJob(${j.id})">Từ chối</button>
                        </td>
                    `;
                };
                window.renderAdminTable('pendingJobs', window.adminDataCache.pendingJobs, pendingHeaders, pendingRowRenderer, 'pendingJobsContainer');

                // 2. Render all jobs
                const allJobsHeaders = ['Tiêu đề công việc', 'Doanh nghiệp đăng', 'Ngân sách', 'Thời hạn', 'Ngày tạo', 'Trạng thái', 'Thao tác'];
                const allJobsRowRenderer = (j, globalIndex) => {
                    const statusBadge = j.status === 'Open'
                        ? '<span class="admin-badge active">Đang nhận đề xuất</span>'
                        : j.status === 'In_Progress'
                        ? '<span class="admin-badge student">Đang thực hiện</span>'
                        : '<span class="admin-badge" style="background:#e2e8f0; color:#334155;">Đóng</span>';

                    return `
                        <td class="fw-semibold">${escapeHtml(j.title)}</td>
                        <td>${escapeHtml(j.businessName)}</td>
                        <td class="text-primary fw-bold">${new Intl.NumberFormat('vi-VN').format(j.budget)} đ</td>
                        <td>${j.deadline}</td>
                        <td>${j.createdAt}</td>
                        <td>${statusBadge}</td>
                        <td>
                            <button class="btn-admin-action delete" onclick="deleteJobPost(${j.id})">Gỡ tin</button>
                        </td>
                    `;
                };
                window.renderAdminTable('allJobs', window.adminDataCache.allJobs, allJobsHeaders, allJobsRowRenderer, 'allJobsContainer');
            }

            async function approveJob(jobId) {
                if (!confirm("Bạn có chắc chắn muốn duyệt tin tuyển dụng này?")) return;
                try {
                    const res = await fetch(`/Home/ApproveJob?id=${jobId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast("Đã duyệt tin thành công!", "success");
                        // Clear pending job locally
                        const idx = adminPendingJobsData.findIndex(x => x.id === jobId);
                        if (idx > -1) adminPendingJobsData.splice(idx, 1);
                        window.adminDataCache.allJobs = []; // invalidate cache
                        renderAdminJobs(false);
                    } else {
                        showToast(data.message || "Lỗi khi duyệt tin", "error");
                    }
                } catch (err) {
                    showToast("Lỗi kết nối", "error");
                }
            }

            async function rejectJob(jobId) {
                if (!confirm("Bạn có chắc chắn muốn từ chối tin tuyển dụng này?")) return;
                try {
                    const res = await fetch(`/Home/RejectJob?id=${jobId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast("Đã từ chối tin.", "success");
                        // Clear pending job locally
                        const idx = adminPendingJobsData.findIndex(x => x.id === jobId);
                        if (idx > -1) adminPendingJobsData.splice(idx, 1);
                        window.adminDataCache.allJobs = []; // invalidate cache
                        renderAdminJobs(false);
                    } else {
                        showToast(data.message || "Lỗi khi từ chối tin", "error");
                    }
                } catch (err) {
                    showToast("Lỗi kết nối", "error");
                }
            }

            async function deleteJobPost(jobId) {
                if (!confirm("Bạn có chắc chắn muốn gỡ (xóa) tin tuyển dụng này khỏi hệ thống?")) return;

                try {
                    const res = await fetch(`/Home/DeleteJobPost?jobId=${jobId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast("Đã gỡ tin tuyển dụng thành công!", "success");
                        window.adminDataCache.allJobs = []; // invalidate cache
                        renderAdminJobs(false);
                        updateAdminStats();
                    } else {
                        showToast("Lỗi khi gỡ tin.", "error");
                    }
                } catch (err) {
                    console.error(err);
                    showToast("Không thể kết nối đến máy chủ.", "error");
                }
            }

            async function renderAdminTxs(isPagedReload = false) {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Lịch sử giao dịch toàn hệ thống";

                if (!isPagedReload || !window.adminDataCache.txs || window.adminDataCache.txs.length === 0) {
                    showSpinner(body);
                    try {
                        const res = await fetch('/Home/GetAdminTransactions');
                        window.adminDataCache.txs = await res.json();
                    } catch (err) {
                        body.innerHTML = '<p class="text-danger text-center py-4">Lỗi khi tải lịch sử giao dịch.</p>';
                        console.error(err);
                        return;
                    }
                }

                const txs = window.adminDataCache.txs;
                const headers = ['Mã GD', 'Tài khoản', 'Số tiền', 'Loại GD', 'Nội dung', 'Ngày GD', 'Trạng thái'];

                const rowRenderer = (t, globalIndex) => {
                    const statusBadge = t.status === 'Success'
                        ? '<span class="admin-badge active">Thành công</span>'
                        : t.status === 'Pending'
                        ? '<span class="admin-badge amber">Chờ xử lý</span>'
                        : '<span class="admin-badge banned">Thất bại</span>';

                    let typeText = t.type;
                    if (t.type === 'Deposit') typeText = 'Nạp tiền';
                    else if (t.type === 'Withdraw') typeText = 'Rút tiền';
                    else if (t.type === 'Holding') typeText = 'Tạm giữ';
                    else if (t.type === 'Release') typeText = 'Hoàn tất GD';

                    return `
                        <td>GD#${t.id}</td>
                        <td>${escapeHtml(t.userEmail)}</td>
                        <td class="fw-bold ${t.type === 'Deposit' || t.type === 'Release' ? 'text-success' : 'text-danger'}">
                            ${t.type === 'Deposit' || t.type === 'Release' ? '+' : '-'} ${new Intl.NumberFormat('vi-VN').format(t.amount)} đ
                        </td>
                        <td><span class="fw-semibold">${typeText}</span></td>
                        <td>${escapeHtml(t.description || 'Không có')}</td>
                        <td>${t.createdAt}</td>
                        <td>${statusBadge}</td>
                    `;
                };

                window.renderAdminTable('txs', txs, headers, rowRenderer, 'adminSectionBody');
            }

            function statusBadgeHtml(statusKey, label) {
                if (statusKey === 'Resolved') return `<span class="admin-badge active">${label}</span>`;
                if (statusKey === 'InProgress') return `<span class="admin-badge amber">${label}</span>`;
                return `<span class="admin-badge" style="background:#e2e8f0; color:#334155;">${label}</span>`;
            }

            function statusSelectHtml(id, statusKey, controller) {
                const options = [
                    { key: 'Pending', label: controller === 'Support' ? 'Đã tiếp nhận' : 'Đã ghi nhận' },
                    { key: 'InProgress', label: 'Đang xử lý' },
                    { key: 'Resolved', label: 'Đã xử lý' }
                ];
                let bg = '#f1f5f9';
                let color = '#334155';
                let border = '#cbd5e1';
                if (statusKey === 'InProgress') {
                    bg = '#fef3c7';
                    color = '#92400e';
                    border = '#fde68a';
                } else if (statusKey === 'Resolved') {
                    bg = '#d1fae5';
                    color = '#065f46';
                    border = '#a7f3d0';
                }
                const optionsHtml = options.map(o => `<option value="${o.key}" ${o.key === statusKey ? 'selected' : ''} style="background-color: #ffffff; color: #334155;">${o.label}</option>`).join('');
                return `<select class="form-select form-select-sm" style="width:auto; display:inline-block; font-weight: 600; background-color: ${bg}; color: ${color}; border-color: ${border}; transition: all 0.2s;" onchange="this.style.backgroundColor = this.value === 'InProgress' ? '#fef3c7' : this.value === 'Resolved' ? '#d1fae5' : '#f1f5f9'; this.style.color = this.value === 'InProgress' ? '#92400e' : this.value === 'Resolved' ? '#065f46' : '#334155'; this.style.borderColor = this.value === 'InProgress' ? '#fde68a' : this.value === 'Resolved' ? '#a7f3d0' : '#cbd5e1'; updateAdminItemStatus('${controller}', ${id}, this.value)">${optionsHtml}</select>`;
            }

            async function renderAdminSupport(isPagedReload = false) {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Yêu cầu hỗ trợ từ người dùng";

                if (!isPagedReload || !window.adminDataCache.support || window.adminDataCache.support.length === 0) {
                    showSpinner(body);
                    try {
                        const res = await fetch('/Support/GetAllRequests');
                        const data = await res.json();
                        if (!data.success) {
                            body.innerHTML = '<p class="text-danger text-center py-4">Không có quyền xem dữ liệu này.</p>';
                            return;
                        }
                        window.adminDataCache.support = data.requests || [];
                    } catch (err) {
                        body.innerHTML = '<p class="text-danger text-center py-4">Lỗi khi tải danh sách yêu cầu hỗ trợ.</p>';
                        console.error(err);
                        return;
                    }
                }

                const requests = window.adminDataCache.support;
                const headers = ['Người gửi', 'Tiêu đề', 'Loại', 'Nội dung', 'Ngày gửi', 'Trạng thái'];

                const rowRenderer = (r, globalIndex) => {
                    return `
                        <td>
                            <div class="fw-semibold">${escapeHtml(r.userName)}</div>
                            <div class="text-muted" style="font-size:0.8rem;">${escapeHtml(r.userEmail)}</div>
                        </td>
                        <td class="fw-semibold">${escapeHtml(r.subject)}</td>
                        <td><span class="admin-badge" style="background: #e2e8f0; color: #475569;">${escapeHtml(r.category)}</span></td>
                        <td style="max-width:280px; white-space:pre-wrap;">${escapeHtml(r.message)}</td>
                        <td>${r.createdAt}</td>
                        <td>${statusSelectHtml(r.id, r.status, 'Support')}</td>
                    `;
                };

                window.renderAdminTable('support', requests, headers, rowRenderer, 'adminSectionBody');
            }

            async function renderAdminFeedback(isPagedReload = false) {
                const title = document.getElementById('adminSectionTitle');
                const body = document.getElementById('adminSectionBody');
                title.textContent = "Góp ý & Báo lỗi từ người dùng";

                if (!isPagedReload || !window.adminDataCache.feedback || window.adminDataCache.feedback.length === 0) {
                    showSpinner(body);
                    try {
                        const res = await fetch('/Feedback/GetAllFeedback');
                        const data = await res.json();
                        if (!data.success) {
                            body.innerHTML = '<p class="text-danger text-center py-4">Không có quyền xem dữ liệu này.</p>';
                            return;
                        }
                        window.adminDataCache.feedback = data.items || [];
                    } catch (err) {
                        body.innerHTML = '<p class="text-danger text-center py-4">Lỗi khi tải danh sách phản hồi.</p>';
                        console.error(err);
                        return;
                    }
                }

                const items = window.adminDataCache.feedback;
                const headers = ['Người gửi', 'Tiêu đề', 'Loại', 'Chi tiết', 'Ngày gửi', 'Trạng thái'];

                const rowRenderer = (f, globalIndex) => {
                    return `
                        <td>
                            <div class="fw-semibold">${escapeHtml(f.userName)}</div>
                            <div class="text-muted" style="font-size:0.8rem;">${escapeHtml(f.userEmail)}</div>
                        </td>
                        <td class="fw-semibold">${escapeHtml(f.title)}</td>
                        <td>${f.type === 'Báo lỗi hệ thống' ? '<span class="admin-badge banned">' + escapeHtml(f.type) + '</span>' : '<span class="admin-badge active" style="background:#eff6ff; color:#1d4ed8;">' + escapeHtml(f.type) + '</span>'}</td>
                        <td style="max-width:280px; white-space:pre-wrap;">${escapeHtml(f.details)}</td>
                        <td>${f.createdAt}</td>
                        <td>${statusSelectHtml(f.id, f.status, 'Feedback')}</td>
                    `;
                };

                window.renderAdminTable('feedback', items, headers, rowRenderer, 'adminSectionBody');
            }

            async function updateAdminItemStatus(controller, id, status) {
                try {
                    const res = await fetch(`/${controller}/UpdateStatus`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        },
                        body: `id=${id}&status=${status}`
                    });
                    const data = await res.json();
                    if (data.success) {
                        showToast(data.message || 'Đã cập nhật trạng thái.', 'success');
                        if (controller === 'Support') {
                            const item = window.adminDataCache.support.find(x => x.id === id);
                            if (item) item.status = status;
                        } else if (controller === 'Feedback') {
                            const item = window.adminDataCache.feedback.find(x => x.id === id);
                            if (item) item.status = status;
                        }
                    } else {
                        showToast(data.message || 'Lỗi khi cập nhật trạng thái.', 'error');
                    }
                } catch (err) {
                    showToast('Lỗi kết nối máy chủ.', 'error');
                    console.error(err);
                }
            }

            function escapeHtml(str) {
                if (!str) return '';
                const div = document.createElement('div');
                div.textContent = str;
                return div.innerHTML;
            }
        </script>
    }
}

