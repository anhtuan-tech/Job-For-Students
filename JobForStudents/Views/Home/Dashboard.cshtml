                            <p style="font-size: 0.8rem; color: #64748b; margin: 0; line-height: 1.5;">Phương pháp lập kế hoạch khoa học giúp bạn hoàn thành deadline.</p>
                        </div>
                    </div>
                    <!-- Card 3 -->
                    <div data-tip-id="tip-portfolio" onclick="openTipModal('tip-portfolio')" style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.01); transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div style="height: 100px; background: linear-gradient(135deg, #fdf2f8, #fbcfe8); display: flex; align-items: center; justify-content: center; color: #db2777;"><i data-lucide="briefcase" style="width: 32px; height: 32px;"></i></div>
                        <div style="padding: 16px;">
                            <h3 style="font-size: 0.95rem; font-weight: 700; color: #1e293b; margin: 0 0 8px 0; line-height: 1.4;">Xây dựng Portfolio từ con số 0</h3>
                            <p style="font-size: 0.8rem; color: #64748b; margin: 0; line-height: 1.5;">Cách tận dụng bài tập trên trường để làm Portfolio hút mắt.</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    }
</div>

@if (User.IsInRole("Business"))
{
    <!-- Post Job Modal -->
    <div class="modal fade" id="postJobModal" tabindex="-1" aria-labelledby="postJobModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" style="border-radius: 12px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
                <div class="modal-header" style="background: #f8fafc; border-bottom: 1px solid #e2e8f0; border-radius: 12px 12px 0 0;">
                    <h5 class="modal-title fw-bold text-dark" id="postJobModalTitle">Đăng tin tuyển dụng mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3 d-flex gap-2 align-items-center flex-wrap" id="jobTemplateBar">
                        <select class="form-select" id="jobTemplateSelect" style="max-width:280px;">
                            <option value="">Chọn mẫu tin có sẵn...</option>
                        </select>
                        <button type="button" class="btn btn-light btn-sm rounded-pill px-3" id="btnSaveAsTemplate">
                            <i data-lucide="bookmark-plus" style="width:14px;height:14px;"></i> Lưu thành mẫu
                        </button>
                        <button type="button" class="btn btn-light btn-sm rounded-pill px-3 text-danger d-none" id="btnDeleteTemplate">
                            <i data-lucide="trash-2" style="width:14px;height:14px;"></i> Xóa mẫu này
                        </button>
                    </div>
                    <form id="postJobForm">
                        <input type="hidden" id="jobFormMode" name="jobMode" value="new" />
                        <input type="hidden" id="jobFormId" name="jobId" value="" />
                        <input type="hidden" id="jobFormSaveMode" name="saveMode" value="publish" />
                        <div class="mb-3">
                            <label for="jobTitle" class="form-label fw-semibold text-secondary">Tiêu đề công việc <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="jobTitle" name="title" required placeholder="VD: Thiết kế logo cho công ty XYZ">
                        </div>

                        <div class="mb-3">
                            <label for="jobCategory" class="form-label fw-semibold text-secondary">Danh mục <span class="text-danger">*</span></label>
                            <select class="form-select" id="jobCategory" name="category" required>
                                <option value="" disabled selected>Chọn danh mục</option>
                                <option value="IT & Lập trình">IT & Lập trình</option>
                                <option value="Thiết kế & Đồ họa">Thiết kế & Đồ họa</option>
                                <option value="Viết lách & Dịch thuật">Viết lách & Dịch thuật</option>
                                <option value="Sales & Marketing">Sales & Marketing</option>
                                <option value="Video & Photography">Video & Photography</option>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="jobBudget" class="form-label fw-semibold text-secondary">Ngân sách (VNĐ) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="jobBudget" name="budget" required min="100000" step="10000" placeholder="VD: 500000">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="jobDeadline" class="form-label fw-semibold text-secondary">Hạn chót ứng tuyển <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="jobDeadline" name="deadline" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="jobDescription" class="form-label fw-semibold text-secondary">Mô tả công việc <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="jobDescription" name="description" rows="5" required placeholder="Mô tả chi tiết yêu cầu công việc..."></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #e2e8f0; background: #f8fafc; border-radius: 0 0 12px 12px;">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" id="btnSaveDraftJob">Lưu nháp</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" id="btnSubmitJob" style="background: #4F46E5; border: none;">Đăng tin ngay</button>
                </div>
            </div>
        </div>
    </div>
}
</div>

<form id="logoutForm" asp-controller="Auth" asp-action="LogoutPost" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@if (!User.Identity.IsAuthenticated)
{
    <script>
        document.addEventListener('click', function(e) {
        // Cho phép click vào Đăng nhập, Đăng ký và Logo
        if (e.target.closest('a[href="/Auth/Login"], a[href="/Auth/Register"], .j4s-brand')) {
        return;
        }
        // Chặn click vào các thành phần tương tác và chuyển hướng
        if (e.target.closest('a, button, input, select, .job-card, .category-card')) {
        e.preventDefault();
        e.stopPropagation();
        window.location.href = '/Auth/Login';
        }
        }, true);
    </script>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        // Hamburger menu toggle
        document.getElementById('menuToggle')?.addEventListener('click', function () {
        const sidebar = document.getElementById('sidebar');
        if (!sidebar) return;

        if (window.matchMedia('(max-width: 768px)').matches) {
            sidebar.classList.toggle('open');
        } else {
            document.body.classList.toggle('sidebar-collapsed');
        }
        });
    </script>

    @if (User.IsInRole("Business"))
    {
        <script>
            window.businessActiveJobsCount = @Model.BusinessActiveJobsCount;
            document.addEventListener('DOMContentLoaded', () => {
            // Bind buttons for Business dashboard
            document.getElementById('btnPostJobBusiness')?.addEventListener('click', () => {
            window.preparePostJobForm?.();
            document.getElementById('btnPostJob')?.click();
            });
            document.getElementById('btnPostJob')?.addEventListener('click', () => {
            window.preparePostJobForm?.();
            });
            document.getElementById('btnSearchCandidatesBusiness')?.addEventListener('click', () => {
            document.getElementById('navTopFreelancer')?.click();
            });
            document.getElementById('btnSeeAllCandidates')?.addEventListener('click', (e) => {
            e.preventDefault();
            document.getElementById('navTopFreelancer')?.click();
            });
            document.getElementById('btnSeeAllJobs')?.addEventListener('click', (e) => {
            e.preventDefault();
            document.getElementById('navProjects')?.click();
            });
            document.getElementById('btnManageJobsSidebar')?.addEventListener('click', () => {
            document.getElementById('navProjects')?.click();
            });
            document.getElementById('btnUpgradePackage')?.addEventListener('click', () => {
            document.getElementById('navWalletCurrent')?.click();
            });
            document.getElementById('navBusinessWallet')?.addEventListener('click', (e) => {
            e.preventDefault();
            document.getElementById('navWalletCurrent')?.click();
            });

            // Gói dịch vụ & Thanh toán toggle
            document.getElementById('navWalletParent')?.addEventListener('click', function(e) {
            e.preventDefault();
            const submenu = document.getElementById('walletSubmenu');
            const chevron = this.querySelector('.submenu-chevron');
            if (submenu && chevron) {
            if (submenu.style.display === 'none') {
            submenu.style.display = 'flex';
            chevron.style.transform = 'rotate(180deg)';
            } else {
            submenu.style.display = 'none';
            chevron.style.transform = 'rotate(0deg)';
            }
            }
            });
            });

            // --- Business Wallet & Payment Features Implementation ---
            // --- Business Wallet & Payment Features Implementation ---
            async function getWalletData() {
            try {
            const res = await fetch('/Home/GetWalletInfo');
            const data = await res.json();
            if (data && data.success) {
            window.updateRightSidebarPackageWidget(
            data.activePackageName,
            data.activePackageExpiry,
            data.activePackageUsedCount,
            data.activePackageMaxCount
            );
            }
            return data;
            } catch (e) {
            console.error('Error fetching wallet info:', e);
            return null;
            }
            }

            window.updateRightSidebarPackageWidget = function(activePackageName, activePackageExpiry, activePackageUsedCount, activePackageMaxCount) {
            const pkgCard = document.getElementById('sidebarServicePkgCard');
            if (!pkgCard) return;

            let contentHtml = '';
            if (activePackageName === "Gói Premium") {
            const progress = Math.min(100, (activePackageUsedCount * 100) / 20);
            contentHtml = `
            <div class="service-pkg-header">
            <span class="service-pkg-name"><i data-lucide="star" style="width:18px;height:18px;color:#f59e0b;fill:#f59e0b;"></i> Gói Premium</span>
            <span class="service-pkg-status active" style="background:#d1fae5; color:#065f46; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Đang hoạt động</span>
            </div>
            <div class="service-pkg-expiry">Hiệu lực đến: ${activePackageExpiry}</div>
            <div class="service-pkg-bullets">
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 20 tin tuyển dụng</span></div>
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị tin ưu tiên</span></div>
            <div class="service-pkg-bullet" style="padding-left: 22px;"><span>Truy cập hồ sơ ứng viên không giới hạn</span></div>
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hỗ trợ tuyển dụng ưu tiên</span></div>
            </div>
            <div class="service-pkg-usage">
            <span>Đã sử dụng</span>
            <span>${activePackageUsedCount}/20 tin</span>
            </div>
            <div class="service-pkg-progress-bar">
            <div class="service-pkg-progress-fill" style="width: ${progress}%;"></div>
            </div>
            `;
            } else if (activePackageName === "Gói VIP") {
            const progress = Math.min(100, (activePackageUsedCount * 100) / 5);
            contentHtml = `
            <div class="service-pkg-header">
            <span class="service-pkg-name"><i data-lucide="star" style="width:18px;height:18px;color:#f59e0b;fill:#f59e0b;"></i> Gói VIP</span>
            <span class="service-pkg-status active" style="background:#fef3c7; color:#92400e; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Đang hoạt động</span>
            </div>
            <div class="service-pkg-expiry">Hiệu lực đến: ${activePackageExpiry}</div>
            <div class="service-pkg-bullets">
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 5 tin tuyển dụng</span></div>
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị nhãn VIP nổi bật</span></div>
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Duyệt tin nhanh trong 1 giờ</span></div>
            </div>
            <div class="service-pkg-usage">
            <span>Đã sử dụng</span>
            <span>${activePackageUsedCount}/5 tin</span>
            </div>
            <div class="service-pkg-progress-bar">
            <div class="service-pkg-progress-fill" style="width: ${progress}%;"></div>
            </div>
            `;
            } else {
            const progress = activePackageUsedCount >= 1 ? 100 : 0;
            contentHtml = `
            <div class="service-pkg-header">
            <span class="service-pkg-name"><i data-lucide="briefcase" style="width:18px;height:18px;color:#64748b;"></i> Gói Thường</span>
            <span class="service-pkg-status text-muted" style="background:#f1f5f9; padding:2px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;">Mặc định</span>
            </div>
            <div class="service-pkg-expiry">Hiệu lực: Vĩnh viễn</div>
            <div class="service-pkg-bullets">
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Đăng tối đa 1 tin tuyển dụng</span></div>
            <div class="service-pkg-bullet"><i data-lucide="check" style="width:14px;height:14px;"></i> <span>Hiển thị chuẩn trên trang chủ</span></div>
            </div>
            <div class="service-pkg-usage">
            <span>Đã sử dụng</span>
            <span>${activePackageUsedCount}/1 tin</span>
            </div>
            <div class="service-pkg-progress-bar">
            <div class="service-pkg-progress-fill" style="width: ${progress}%;"></div>
            </div>
            `;
            }

            pkgCard.innerHTML = contentHtml;
            if (window.lucide) lucide.createIcons();
            }

            window.renderBusinessWalletCurrent = async function() {
            if (window.depositCountdownInterval) {
            clearInterval(window.depositCountdownInterval);
            }
            const mainContent = document.getElementById('mainContent');
            if (!mainContent) return;

            mainContent.innerHTML = `
            <div class="d-flex justify-content-center align-items-center py-5">
            <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
            </div>
            </div>
            `;

            const walletData = await getWalletData();
            if (!walletData || !walletData.success) {
            mainContent.innerHTML = `
            <div class="alert alert-danger" role="alert">
            Không thể tải thông tin ví. Vui lòng thử lại sau.
            </div>
            `;
            return;
            }

            let currentPkg = walletData.activePackageName || "Gói Thường";
            let pkgBadge = '<span class="badge bg-secondary">Miễn phí</span>';
            if (currentPkg === "Gói Premium") {
            pkgBadge = '<span class="badge bg-success" style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:12px; font-size:0.75rem; font-weight:600;"><i data-lucide="star" style="width:12px;height:12px;margin-right:2px;fill:#f59e0b;color:#f59e0b;"></i> Premium</span>';
            } else if (currentPkg === "Gói VIP") {
            pkgBadge = '<span class="badge bg-warning text-dark"><i data-lucide="star" style="width:12px;height:12px;margin-right:2px;"></i> VIP</span>';
            }

            mainContent.innerHTML = `
            <div class="page-header mb-4">
            <h1 class="page-title"><i data-lucide="package" style="width:24px;height:24px;"></i> Gói dịch vụ hiện tại</h1>
            <p class="page-subtitle">Nâng cấp tài khoản để tiếp cận nhiều ứng viên chất lượng hơn</p>
            </div>

            <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-4" style="background: linear-gradient(135deg, #f8fafc, #edf2f7); border-radius: 16px;">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
            <div class="text-muted small uppercase fw-bold mb-1">Tài khoản của bạn</div>
            <h4 class="mb-1 fw-bold text-slate-800 d-flex align-items-center gap-2">
            ${currentPkg} ${pkgBadge}
            </h4>
            <p class="text-muted mb-0 small">Sử dụng dịch vụ đăng tin và tuyển dụng tối ưu trên J4S</p>
            </div>
            <div class="text-end">
            <div class="text-muted small fw-bold mb-1">Số dư khả dụng</div>
            <h3 class="mb-0 fw-extrabold text-indigo-600">${new Intl.NumberFormat('vi-VN').format(walletData.balance)} đ</h3>
            </div>
            </div>
            </div>
            </div>

            <h3 class="section-title mb-3" style="font-weight: 700; color: #1e293b;">Bảng giá gói dịch vụ tuyển dụng</h3>
            <div class="row g-4">
            <!-- Free Package -->
            <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-up" style="border-radius: 16px; border: 1px solid #e2e8f0 !important;">
            <div class="card-body p-4 d-flex flex-column">
            <div class="mb-3">
            <span class="badge bg-light text-muted fw-semibold px-3 py-2" style="border-radius: 20px;">Gói Thường</span>
            </div>
            <h2 class="fw-extrabold mb-3 text-slate-800">Mặc định <span style="font-size: 1rem; font-weight: normal; color: #64748b;">/ Vĩnh viễn</span></h2>
            <p class="text-muted small mb-4">Phù hợp cho doanh nghiệp nhỏ trải nghiệm ứng dụng.</p>
            <hr class="my-3 text-muted">
            <ul class="list-unstyled flex-grow-1 mb-4" style="line-height: 2;">
            <li class="small"><i data-lucide="check" class="text-success me-2" style="width:16px;height:16px;"></i>Đăng tối đa 1 tin tuyển dụng</li>
            <li class="small"><i data-lucide="check" class="text-success me-2" style="width:16px;height:16px;"></i>Hiển thị chuẩn trên trang chủ</li>
            <li class="small text-muted"><i data-lucide="x" class="text-danger me-2" style="width:16px;height:16px;"></i>Không ưu tiên duyệt bài</li>
            <li class="small text-muted"><i data-lucide="x" class="text-danger me-2" style="width:16px;height:16px;"></i>Không có nhãn nổi bật</li>
            </ul>
            <button class="btn btn-outline-secondary w-100 py-2.5 fw-bold mt-auto" style="border-radius: 10px;" disabled>Đang hoạt động</button>
            </div>
            </div>
            </div>

            <!-- VIP Package -->
            <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-up position-relative" style="border-radius: 16px; border: ${currentPkg === 'Gói VIP' ? '2px solid #f59e0b' : '1px solid #e2e8f0'} !important;">
            ${currentPkg === 'Gói VIP' ? '<span class="position-absolute top-0 start-50 translate-middle badge bg-warning text-dark px-3 py-1.5 fw-bold" style="border-radius: 20px;">Gói đang dùng</span>' : ''}
            <div class="card-body p-4 d-flex flex-column">
            <div class="mb-3">
            <span class="badge bg-warning text-dark fw-semibold px-3 py-2" style="border-radius: 20px;"><i data-lucide="star" style="width:14px;height:14px;margin-right:4px;"></i>Gói VIP</span>
            </div>
            <h2 class="fw-extrabold mb-3 text-warning">30.000 đ <span style="font-size: 1rem; font-weight: normal; color: #64748b;">/ 30 ngày</span></h2>
