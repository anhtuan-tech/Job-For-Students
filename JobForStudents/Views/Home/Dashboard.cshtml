<!-- Hidden JSON data for JavaScript -->
<script type="application/json" id="initialJobsData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Jobs, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase, Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping }))</script>

<!-- ============================================
     1. THANH ĐIỀU HƯỚNG TRÊN CÙNG (TOP NAV)
     ============================================ -->
<nav class="top-nav @(User.IsInRole("Business") ? "nav-business" : User.IsInRole("Admin") ? "nav-admin" : "")" id="topNav">
    <!-- Logo + Hamburger -->
    <div class="nav-left">
        <a href="/" class="j4s-brand text-decoration-none">
            <div class="j4s-logo-box">
                @if (User.IsInRole("Admin"))
                {
                    <i data-lucide="shield" style="width:20px;height:20px;stroke-width:2.5;"></i>
                }
                else if (User.IsInRole("Business"))
                {
                    <i data-lucide="briefcase" style="width:20px;height:20px;stroke-width:2.5;"></i>
                }
                else
                {
                    <i data-lucide="graduation-cap" style="width:20px;height:20px;stroke-width:2.5;"></i>
                }
            </div>
            <span class="j4s-logo-text">J4S</span>
        </a>
        <button class="hamburger" id="menuToggle" aria-label="Toggle menu">
            <i data-lucide="menu" style="width:20px;height:20px;"></i>
        </button>
    </div>

    <!-- Thanh tìm kiếm -->
    @if (!User.IsInRole("Admin"))
    {
        <div class="nav-search">
            <i data-lucide="search" class="search-icon" style="width:16px;height:16px;"></i>
            @if (User.IsInRole("Business"))
            {
                <input type="text" placeholder="Tìm hồ sơ ứng viên, bài đăng, kỹ năng..." id="searchInput" />
            }
            else
            {
                <input type="text" placeholder="Tìm kiếm công việc, kỹ năng..." id="searchInput" />
            }
        </div>
    }

    <!-- Phần bên phải -->
    <div class="nav-right">
        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (User.IsInRole("Business"))
            {
                <a href="/" target="_blank" class="view-job-posts-link" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border: 1.5px solid #cbd5e1; border-radius: 9999px; text-decoration: none; font-size: 0.85rem; font-weight: 600; color: #475569; margin-right: 8px; background: white;"><i data-lucide="external-link" style="width:14px;height:14px;"></i> Xem trang việc làm</a>
            }
            else if (!User.IsInRole("Student") && !User.IsInRole("Admin"))
            {
                <button class="btn-find-freelancer" id="btnFindFreelancer">
                    <i data-lucide="users" style="width:14px;height:14px;"></i>
                    Tìm freelancer
                </button>
            }

            <!-- Notification Bell Dropdown -->
            <div class="dropdown">
                <button class="notification-btn" id="notificationBtn" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside" aria-label="Thông báo">
                    <i data-lucide="bell" style="width:20px;height:20px;"></i>
                    <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="width: 350px; padding: 0; border-radius: 12px; overflow: hidden;" aria-labelledby="notificationBtn">
                    <div style="padding: 16px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                        <h6 style="margin: 0; font-weight: 600; color: #1e293b;">Thông báo</h6>
                        <a href="#" id="btnMarkAllRead" style="font-size: 0.8rem; color: #0284c7; text-decoration: none;">Đánh dấu đã đọc</a>
                    </div>
                    <div id="notificationList" style="max-height: 380px; overflow-y: auto;">
                        <div class="text-center p-4 text-muted" style="font-size: 0.85rem;">
                            <i data-lucide="bell-off" style="width: 24px; height: 24px; margin-bottom: 8px; color: #cbd5e1;"></i>
                            <br />Không có thông báo mới
                        </div>
                    </div>
                </div>
            </div>

            <!-- User Menu Dropdown -->
            <div class="dropdown">
                <div class="user-profile" id="userProfile" data-email="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" data-user-id="@Model.CurrentUserId" data-user-role="@Model.CurrentUserRole">
                    <div class="user-avatar" style="background: @(string.IsNullOrEmpty(Model.CurrentUserAvatarUrl) ? "linear-gradient(135deg, #0ea5e9, #38bdf8)" : "none");">
                        @if (!string.IsNullOrEmpty(Model.CurrentUserAvatarUrl))
                        {
                            <img src="@Model.CurrentUserAvatarUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <span>@(Model.CurrentUserName.Length >= 2 ? Model.CurrentUserName[..2].ToUpper() : "US")</span>
                        }
                    </div>
                    <div class="user-info">
                        <span class="user-name">@Model.CurrentUserName</span>
                        <span class="user-role">@(User.IsInRole("Student") ? "Freelancer" : User.IsInRole("Business") ? "Nhà tuyển dụng" : "Admin")</span>
                    </div>
                    <i data-lucide="chevron-down" class="dropdown-arrow" style="width:14px;height:14px;"></i>
                </div>
            </div>
        }
        else
        {
            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-info rounded-pill px-4 btn-sm fw-semibold" style="border-color: #bae6fd; color: #0284c7;">Đăng nhập</a>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-info text-white rounded-pill px-4 btn-sm fw-semibold" style="background-color: #0ea5e9; border: none;">Đăng ký</a>
        }
    </div>
</nav>

<!-- ============================================
     BỐ CỤC CHÍNH 3 CỘT
     ============================================ -->
