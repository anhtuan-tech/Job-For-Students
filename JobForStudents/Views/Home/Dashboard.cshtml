                        </a>
                        <a href="#" class="sidebar-item" data-nav="wallet-deposit" id="navWalletDeposit" style="font-size:0.85rem; padding:8px 12px;">
                            <span class="item-icon"><i data-lucide="plus-circle" style="width:14px;height:14px;"></i></span>
