            window.generateDepositQR = async function() {
            const input = document.getElementById('depositAmountInput');
            if (!input) return;

            const amount = parseInt(input.value);
            const errorEl = document.getElementById('amountError');

            if (isNaN(amount) || amount <= 0 || amount % 50000 !== 0) {
            errorEl?.classList.remove('d-none');
            return;
            }
            errorEl?.classList.add('d-none');

            const submitBtn = document.querySelector('[onclick="generateDepositQR()"]');
            if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang tạo mã...`;
            }

            try {
            const response = await fetch('/Home/DepositMoney', {
            method: 'POST',
            headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
            },
            body: JSON.stringify({ Amount: amount })
            });

            const data = await response.json();
            if (data.success) {
            showQRPanel(data);
            } else {
            showToast(data.message || 'Tạo mã nạp tiền thất bại.', 'error');
            if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = `<i data-lucide="qr-code" class="me-2" style="width:20px;height:20px;"></i>Tạo mã QR nạp tiền`;
            if (window.lucide) lucide.createIcons();
            }
