                            <button class="btn-indigo-outline" id="btnSearchCandidatesBusiness"><i data-lucide="search" style="width:18px;height:18px;"></i> Tìm hồ sơ ứng viên</button>
                        </div>
                    </div>
                    <div class="welcome-illustration-business">
                        <img src="~/images/business_illustration.png" alt="Recruitment Illustration" />
                    </div>
                </section>

                <!-- Stat Cards Row -->
                <section class="business-stats-grid">
                    <div class="business-stat-card">
                        <div class="business-stat-icon blue">
                            <i data-lucide="file-text" style="width:24px;height:24px;"></i>
                        </div>
                        <div>
                            <div class="business-stat-val">@Model.BusinessActiveJobsCount</div>
                            <div class="business-stat-label">Tin đang hiển thị</div>
                            <div class="business-stat-sub" style="color: #ef4444; font-weight: 600;">@Model.BusinessRecentJobsSoonExpiringCount tin sắp hết hạn</div>
