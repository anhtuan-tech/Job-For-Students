                    </div>
                    <div class="business-stat-card">
                        <div class="business-stat-icon teal">
                            <i data-lucide="users" style="width:24px;height:24px;"></i>
                        </div>
                        <div>
                            <div class="business-stat-val">@Model.BusinessNewApplicantsCount</div>
                            <div class="business-stat-label">Ứng viên mới</div>
                            <div class="business-stat-sub" style="color: #0d9488; font-weight: 600;">Trong 7 ngày qua</div>
                        </div>
                    </div>
                    <div class="business-stat-card">
