@model JobForStudents.Models.DashboardViewModel
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    // Gradient colors for freelancer avatars without images (strictly Light Blue & White / no purples)
    var avatarGradients = new[] {
        "linear-gradient(135deg, #0ea5e9, #38bdf8)",
        "linear-gradient(135deg, #0284c7, #bae6fd)",
        "linear-gradient(135deg, #14b8a6, #2dd4bf)",
        "linear-gradient(135deg, #f59e0b, #fbbf24)",
        "linear-gradient(135deg, #10b981, #34d399)"
    };
}

<!-- Hidden JSON data for JavaScript -->
<script type="application/json" id="initialJobsData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Jobs, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))</script>

<!-- ============================================
     1. THANH ĐIỀU HƯỚNG TRÊN CÙNG (TOP NAV)
     ============================================ -->
<nav class="top-nav" id="topNav">
    <!-- Logo + Hamburger -->
    <div class="nav-left">
        <a href="/" class="j4s-brand text-decoration-none">
            <div class="j4s-logo-box">
                <i data-lucide="graduation-cap" style="width:20px;height:20px;stroke-width:2.5;"></i>
            </div>
            <span class="j4s-logo-text">J4S</span>
        </a>
        <button class="hamburger" id="menuToggle" aria-label="Toggle menu">
            <i data-lucide="menu" style="width:20px;height:20px;"></i>
        </button>
    </div>

    <!-- Thanh tìm kiếm -->
    <div class="nav-search">
        <i data-lucide="search" class="search-icon" style="width:16px;height:16px;"></i>
        <input type="text" placeholder="Tìm kiếm công việc, kỹ năng..." id="searchInput" />
    </div>

    <!-- Phần bên phải -->
    <div class="nav-right">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <button class="btn-find-freelancer" id="btnFindFreelancer">
                <i data-lucide="users" style="width:14px;height:14px;"></i>
                Tìm freelancer
            </button>

            <!-- Notification Bell Dropdown -->
            <div class="dropdown">
                <button class="notification-btn" id="notificationBtn" aria-label="Thông báo">
                    <i data-lucide="bell" style="width:20px;height:20px;"></i>
                    <span class="notification-badge" style="display: none;">0</span>
                </button>
            </div>

            <!-- User Menu Dropdown -->
            <div class="dropdown">
                <div class="user-profile" id="userProfile" data-bs-toggle="dropdown" aria-expanded="false" data-email="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value">
                    <div class="user-avatar" style="background: @(string.IsNullOrEmpty(Model.CurrentUserAvatarUrl) ? "linear-gradient(135deg, #0ea5e9, #38bdf8)" : "none");">
                        @if (!string.IsNullOrEmpty(Model.CurrentUserAvatarUrl))
                        {
                            <img src="@Model.CurrentUserAvatarUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <span>@(Model.CurrentUserName.Length >= 2 ? Model.CurrentUserName[..2].ToUpper() : "US")</span>
                        }
                    </div>
                    <div class="user-info">
                        <span class="user-name">@Model.CurrentUserName</span>
                        <span class="user-role">@(User.IsInRole("Student") ? "Freelancer" : User.IsInRole("Business") ? "Doanh nghiệp" : "Admin")</span>
                    </div>
                    <i data-lucide="chevron-down" class="dropdown-arrow" style="width:14px;height:14px;"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 12px; min-width: 200px;">
                    <li><a class="dropdown-item py-2 small rounded-3 d-flex align-items-center gap-2" href="#"><i data-lucide="user" style="width:16px;"></i> Hồ sơ cá nhân</a></li>
                    <li><a class="dropdown-item py-2 small rounded-3 d-flex align-items-center gap-2" href="#"><i data-lucide="settings" style="width:16px;"></i> Thiết lập tài khoản</a></li>
                    <li><a class="dropdown-item py-2 small rounded-3 d-flex align-items-center gap-2" href="#"><i data-lucide="shield" style="width:16px;"></i> Bảo mật & Quyền riêng tư</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-controller="Auth" asp-action="LogoutPost" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item py-2 small text-danger rounded-3 d-flex align-items-center gap-2 w-100 border-0 bg-transparent">
                                <i data-lucide="log-out" style="width:16px;"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-info rounded-pill px-4 btn-sm fw-semibold" style="border-color: #bae6fd; color: #0284c7;">Đăng nhập</a>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-info text-white rounded-pill px-4 btn-sm fw-semibold" style="background-color: #0ea5e9; border: none;">Đăng ký</a>
        }
    </div>
</nav>

<!-- ============================================
     BỐ CỤC CHÍNH 3 CỘT
     ============================================ -->
<div class="dashboard-layout">

    <!-- ============================================
         2. CỘT TRÁI - SIDEBAR MENU
         ============================================ -->
    <aside class="sidebar" id="sidebar">
        <!-- Nhóm: VIỆC LÀM -->
        <div class="sidebar-group">
            <div class="sidebar-label">Việc làm</div>
            <a href="#" class="sidebar-item active" data-nav="home" id="navHome">
                <span class="item-icon"><i data-lucide="home" style="width:18px;height:18px;"></i></span>
                Trang chủ
            </a>
            <a href="#" class="sidebar-item" data-nav="find" id="navFindJob">
                <span class="item-icon"><i data-lucide="search" style="width:18px;height:18px;"></i></span>
                Tìm việc
            </a>
            <a href="#" class="sidebar-item" data-nav="saved" id="navSaved">
                <span class="item-icon"><i data-lucide="bookmark" style="width:18px;height:18px;"></i></span>
                Việc đã lưu
            </a>
            <a href="#" class="sidebar-item" data-nav="applied" id="navApplied">
                <span class="item-icon"><i data-lucide="send" style="width:18px;height:18px;"></i></span>
                Đã ứng tuyển
            </a>
            <a href="#" class="sidebar-item" data-nav="projects" id="navProjects">
                <span class="item-icon"><i data-lucide="folder-open" style="width:18px;height:18px;"></i></span>
                Dự án đang làm
            </a>
        </div>

        <!-- Nhóm: QUẢN LÝ -->
        <div class="sidebar-group">
            <div class="sidebar-label">Quản lý</div>
            <a href="#" class="sidebar-item" data-nav="profile" id="navProfile">
                <span class="item-icon"><i data-lucide="user" style="width:18px;height:18px;"></i></span>
                Hồ sơ của tôi
            </a>
            <a href="#" class="sidebar-item" data-nav="messages" id="navMessages">
                <span class="item-icon"><i data-lucide="message-circle" style="width:18px;height:18px;"></i></span>
                Tin nhắn
                <span class="sidebar-badge">3</span>
            </a>
            <a href="#" class="sidebar-item" data-nav="reviews" id="navReviews">
                <span class="item-icon"><i data-lucide="star" style="width:18px;height:18px;"></i></span>
                Đánh giá
            </a>
            <a href="#" class="sidebar-item" data-nav="wallet" id="navWallet">
                <span class="item-icon"><i data-lucide="wallet" style="width:18px;height:18px;"></i></span>
                Ví tiền
            </a>
        </div>

        <!-- Nhóm: KHÁM PHÁ -->
        <div class="sidebar-group">
            <div class="sidebar-label">Khám phá</div>
            <a href="#" class="sidebar-item" data-nav="topFreelancer" id="navTopFreelancer">
                <span class="item-icon"><i data-lucide="award" style="width:18px;height:18px;"></i></span>
                Freelancer nổi bật
            </a>
            <a href="#" class="sidebar-item" data-nav="leaderboard" id="navLeaderboard">
                <span class="item-icon"><i data-lucide="bar-chart-3" style="width:18px;height:18px;"></i></span>
                Bảng xếp hạng
            </a>
            <a href="#" class="sidebar-item" data-nav="blog" id="navBlog">
                <span class="item-icon"><i data-lucide="book-open" style="width:18px;height:18px;"></i></span>
                Blog & Hướng dẫn
            </a>
        </div>

        <!-- Nút Đăng việc mới -->
        <div class="sidebar-bottom">
            <button class="btn-post-job" id="btnPostJob">
                <i data-lucide="plus" style="width:18px;height:18px;"></i>
                Đăng việc mới
            </button>
        </div>
    </aside>

    <!-- ============================================
         VÙNG NỘI DUNG CHÍNH + CỘT PHẢI
         ============================================ -->
    <div class="main-content-wrapper">

        <!-- ============================================
             3. CỘT GIỮA - NỘI DUNG CHÍNH
             ============================================ -->
        <main class="main-content" id="mainContent">

            <!-- === Banner chào mừng === -->
            <section class="welcome-banner" id="welcomeBanner">
                <div class="banner-text">
                    <h1>Kết nối kỹ năng sinh viên<br/>Với công việc bạn cần</h1>
                    <p>Việc nhỏ hôm nay – Thu nhập mỗi ngày</p>
                    <div class="banner-actions">
                        <button class="btn-primary-main" id="btnFindJobNow">
                            <i data-lucide="search" style="width:16px;height:16px;"></i>
                            Tìm việc ngay
                        </button>
                        <button class="btn-outline-main" id="btnPostJobBanner">
                            <i data-lucide="plus-circle" style="width:16px;height:16px;"></i>
                            Đăng việc
                        </button>
                    </div>
                </div>
                <div class="banner-illustration">
                    <img src="~/images/student_working.png" alt="Sinh viên làm việc với laptop" />
                </div>
            </section>

            <!-- === Danh mục phổ biến === -->
            <section id="popularCategories">
                <div class="section-header">
                    <h2 class="section-title">Danh mục phổ biến</h2>
                    <a href="#" class="section-link">
                        Xem tất cả <i data-lucide="chevron-right" style="width:14px;height:14px;"></i>
                    </a>
                </div>
                <div class="categories-grid">
                    <!-- Thiết kế -->
                    <div class="category-card animate-in" data-category="Thiết kế">
                        <div class="category-icon">
                            <i data-lucide="palette" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Thiết kế</div>
                        <div class="category-count">(1200+)</div>
                    </div>
                    <!-- Làm slide -->
                    <div class="category-card animate-in" data-category="Làm slide">
                        <div class="category-icon">
                            <i data-lucide="presentation" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Làm slide</div>
                        <div class="category-count">(860+)</div>
                    </div>
                    <!-- Dịch thuật -->
                    <div class="category-card animate-in" data-category="Dịch thuật">
                        <div class="category-icon">
                            <i data-lucide="languages" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Dịch thuật</div>
                        <div class="category-count">(640+)</div>
                    </div>
                    <!-- Viết content -->
                    <div class="category-card animate-in" data-category="Viết content">
                        <div class="category-icon">
                            <i data-lucide="pen-tool" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Viết content</div>
                        <div class="category-count">(530+)</div>
                    </div>
                    <!-- Code web -->
                    <div class="category-card animate-in" data-category="Code web">
                        <div class="category-icon">
                            <i data-lucide="code-2" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Code web</div>
                        <div class="category-count">(460+)</div>
                    </div>
                    <!-- Edit video -->
                    <div class="category-card animate-in" data-category="Edit video">
                        <div class="category-icon">
                            <i data-lucide="video" style="width:24px;height:24px;"></i>
                        </div>
                        <div class="category-name">Edit video</div>
                        <div class="category-count">(380+)</div>
                    </div>
                </div>
            </section>

            <!-- === Danh sách việc làm mới nhất === -->
            <section id="latestJobs">
                <div class="jobs-header">
                    <h2 class="section-title">Việc làm mới nhất</h2>
                    <div class="jobs-filters">
                        <select class="filter-select" id="filterCategory">
                            <option>Tất cả danh mục</option>
                            <option>Thiết kế</option>
                            <option>Dịch thuật</option>
                            <option>Làm slide</option>
                            <option>Viết content</option>
                            <option>Code web</option>
                            <option>Edit video</option>
                        </select>
                        <select class="filter-select" id="filterSort">
                            <option>Mới nhất</option>
                            <option>Giá cao nhất</option>
                            <option>Sắp hết hạn</option>
                        </select>
                    </div>
                </div>

                <!-- Dynamic Job Feed Container -->
                <div id="jobFeedContainer">
                    @{
                        var iconMap = new Dictionary<string, (string cls, string icon)> {
                            ["Design"] = ("design", "image"),
                            ["Translation"] = ("translate", "file-text"),
                            ["Slides"] = ("slide", "monitor"),
                            ["Content"] = ("content", "pen-tool"),
                            ["Code"] = ("code", "code-2"),
                            ["Video"] = ("video", "video")
                        };
                    }
                    @foreach (var job in Model.Jobs)
                    {
                        var info = iconMap.GetValueOrDefault(job.Category, ("design", "briefcase"));
                        var budgetFormatted = string.Format("{0:N0} đ", job.Budget);
                        var savedClass = job.IsSaved ? "saved" : "";
                        var bookmarkIcon = job.IsSaved ? "bookmark-check" : "bookmark";
                        <div class="job-card animate-in" data-job-id="@job.Id">
                            <div class="job-icon @info.Item1">
                                <i data-lucide="@info.Item2" style="width:22px;height:22px;"></i>
                            </div>
                            <div class="job-info">
                                <h3 class="job-title" data-job-id="@job.Id">@job.Title</h3>
                                <p class="job-desc">@job.Description</p>
                                <div class="job-tags">
                                    @foreach (var tag in job.Tags)
                                    {
                                        <span class="job-tag">@tag</span>
                                    }
                                </div>
                            </div>
                            <div class="job-meta">
                                <span class="job-price">@budgetFormatted</span>
                                <span class="job-deadline">@job.Deadline</span>
                                <span class="job-proposals">@job.ApplicantsCount đề xuất@(job.IsApplied ? " " : "")@if (job.IsApplied) {<span class="applied-badge">Đã ứng tuyển</span>}</span>
                            </div>
                            <button class="job-bookmark @savedClass" data-job-id="@job.Id" aria-label="Lưu việc">
                                <i data-lucide="@bookmarkIcon" style="width:18px;height:18px;"></i>
                            </button>
                        </div>
                    }
                </div>

                <!-- Nút Xem thêm -->
                <button class="view-more-btn" id="btnViewMore">
                    Xem thêm việc làm
                    <i data-lucide="chevron-down" style="width:16px;height:16px;"></i>
                </button>
            </section>
        </main>

        <!-- ============================================
             4. CỘT PHẢI - THÔNG TIN TIỆN ÍCH
             ============================================ -->
        <aside class="right-sidebar" id="rightSidebar">

            <!-- === Box 1: Gợi ý dành cho bạn bởi AI === -->
            <div class="widget-card" id="aiSuggestions">
                <div class="widget-header">
                    <h3 class="widget-title">
                        <span class="ai-icon">✨</span>
                        Gợi ý dành cho bạn bởi AI
                    </h3>
                </div>

                @for (int i = 0; i < Model.TopFreelancers.Count; i++)
                {
                    var freelancer = Model.TopFreelancers[i];
                    var isStar = i == 0;
                    var gradient = avatarGradients[i % avatarGradients.Length];
                    var initials = string.Join("", freelancer.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(w => w[0]));
                    if (initials.Length > 2) initials = initials[..2];

                    <div class="freelancer-item @(isStar ? "star" : "")">
                        <div class="freelancer-avatar" style="background: @gradient;">
                            @if (!string.IsNullOrEmpty(freelancer.Avatar))
                            {
                                <img src="@freelancer.Avatar" alt="@freelancer.Name" />
                            }
                            else
                            {
                                @initials
                            }
                        </div>
                        <div class="freelancer-info">
                            <div class="freelancer-name">@freelancer.Name</div>
                            <div class="freelancer-role">@freelancer.Skill</div>
                            <div class="freelancer-rating">
                                <span class="star">★</span> @freelancer.Rating.ToString("F1") (@freelancer.ReviewsCount)
                            </div>
                        </div>
                        <div class="freelancer-action">
                            <span class="match-badge">@freelancer.MatchPercentage</span>
                            <button class="btn-view-profile">Xem hồ sơ</button>
                        </div>
                    </div>
                }

                <a href="#" class="section-link" style="justify-content:flex-end; margin-top:12px;">
                    Xem tất cả gợi ý <i data-lucide="chevron-right" style="width:14px;height:14px;"></i>
                </a>
            </div>

            <!-- === Box 2: Tổng quan thu nhập === -->
            <div class="income-widget" id="incomeOverview">
                <div class="income-header">
                    <h3>Tổng quan thu nhập</h3>
                    <a href="#" class="widget-link">Xem chi tiết →</a>
                </div>

                <div class="income-stats">
                    <div class="income-stat-item">
                        <div class="label">Thu nhập tháng này</div>
                        <div class="value">@string.Format("{0:N0} đ", Model.TotalEarnings)</div>
                        <div class="change">+12% so với tháng trước</div>
                    </div>
                    <div class="income-stat-item" style="text-align:right;">
                        <div class="label">Đã hoàn thành</div>
                        <div class="value compact">@Model.CompletedJobsCount dự án</div>
                        <div class="change-note">+2 dự án</div>
                    </div>
                </div>

                <div class="income-actions">
                    <button class="income-action-btn" id="btnDeposit">
                        <span class="action-icon"><i data-lucide="download" style="width:20px;height:20px;"></i></span>
                        <span class="action-label">Nạp tiền</span>
                    </button>
                    <button class="income-action-btn" id="btnWithdraw">
                        <span class="action-icon"><i data-lucide="upload" style="width:20px;height:20px;"></i></span>
                        <span class="action-label">Rút tiền</span>
                    </button>
                    <button class="income-action-btn" id="btnHistory">
                        <span class="action-icon"><i data-lucide="clock" style="width:20px;height:20px;"></i></span>
                        <span class="action-label">Lịch sử GD</span>
                    </button>
                    <button class="income-action-btn" id="btnPromo">
                        <span class="action-icon"><i data-lucide="gift" style="width:20px;height:20px;"></i></span>
                        <span class="action-label">Ưu đãi</span>
                    </button>
                </div>
            </div>

            <!-- === Box 3: Banner bảng xếp hạng === -->
            <div class="leaderboard-banner" id="leaderboardBanner">
                <div class="leaderboard-content">
                    <h3>Tham gia bảng xếp hạng</h3>
                    <p>Nhận thưởng hấp dẫn mỗi tháng!</p>
                    <button class="btn-leaderboard" id="btnLeaderboard">
                        Xem ngay
                        <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
                    </button>
                </div>
                <img src="~/images/golden_trophy.png" alt="Cúp vàng bảng xếp hạng" class="leaderboard-trophy-img" />
            </div>

        </aside>
    </div>
</div>

<form id="logoutForm" asp-controller="Auth" asp-action="LogoutPost" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Hamburger menu toggle
        document.getElementById('menuToggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('open');
        });
    </script>
}
